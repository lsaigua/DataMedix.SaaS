@page "/configuracion"
@attribute [Authorize(Roles = "SUPERADMIN,ADMIN")]
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using DataMedix.Application.Interfaces
@using DataMedix.Domain.Entities

@inject AuthenticationStateProvider AuthState
@inject ITenantRepository TenantRepo
@inject IUsuarioRepository UsuarioRepo
@inject IPacienteRepository PacienteRepo
@inject IAuditoriaRepository AuditoriaRepo

<PageTitle>Configuración | DataMedix</PageTitle>

<!-- Header -->
<div class="cfg-header">
    <div class="cfg-header-icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
             stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.07 4.93l-1.41 1.41M4.93 4.93l1.41 1.41M19.07 19.07l-1.41-1.41M4.93 19.07l1.41-1.41M12 2v2M12 20v2M2 12h2M20 12h2"/>
        </svg>
    </div>
    <div>
        <h1 class="cfg-title">Configuración</h1>
        <p class="cfg-subtitle">Información y ajustes del centro de diálisis</p>
    </div>
</div>

<!-- Banners -->
@if (!string.IsNullOrEmpty(_error))
{
    <div class="cfg-banner cfg-banner-error">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        @_error
    </div>
}
@if (!string.IsNullOrEmpty(_exito))
{
    <div class="cfg-banner cfg-banner-success">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        @_exito
    </div>
}

@if (_cargando)
{
    <div class="cfg-loading">
        <div class="cfg-spinner"></div>
        <p>Cargando configuración...</p>
    </div>
}
else if (_tenant != null)
{
    <div class="cfg-grid">

        <!-- ── Info del centro ── -->
        <div class="cfg-card">
            <div class="cfg-card-head">
                <div class="cfg-card-head-icon cfg-icon-blue">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                        <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                </div>
                <h2 class="cfg-card-title">Información del Centro</h2>
            </div>
            <div class="cfg-card-body">

                <div class="cfg-field">
                    <label class="cfg-label">Nombre del Centro <span class="cfg-required">*</span></label>
                    <input class="cfg-input" @bind="_nombreEdit" placeholder="Ej: Clínica de Diálisis XYZ" />
                    <p class="cfg-hint">Nombre que aparece en reportes y documentos.</p>
                </div>

                <div class="cfg-field">
                    <label class="cfg-label">Subdominio</label>
                    <div class="cfg-input-readonly">
                        <span class="cfg-subdomain-slug">@_tenant.Subdomain</span>
                        <span class="cfg-subdomain-suffix">.datamedix.app</span>
                    </div>
                    <p class="cfg-hint">El subdominio no puede cambiarse. Contacte soporte si necesita modificarlo.</p>
                </div>

                <div class="cfg-field">
                    <label class="cfg-label">Estado</label>
                    @if (_tenant.Activo)
                    {
                        <div class="cfg-status cfg-status-active">
                            <span class="cfg-status-dot cfg-dot-active"></span>
                            Activo
                        </div>
                    }
                    else
                    {
                        <div class="cfg-status cfg-status-inactive">
                            <span class="cfg-status-dot cfg-dot-inactive"></span>
                            Inactivo
                        </div>
                    }
                </div>

                <div class="cfg-actions">
                    <button class="cfg-btn-save" @onclick="GuardarNombreAsync" disabled="@_guardando">
                        @if (_guardando)
                        {
                            <span class="cfg-btn-spinner"></span>
                            <span>Guardando...</span>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                            <span>Guardar Cambios</span>
                        }
                    </button>
                </div>

            </div>
        </div>

        <!-- ── Estadísticas ── -->
        <div class="cfg-card">
            <div class="cfg-card-head">
                <div class="cfg-card-head-icon cfg-icon-purple">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/>
                        <line x1="6" y1="20" x2="6" y2="14"/>
                    </svg>
                </div>
                <h2 class="cfg-card-title">Estadísticas del Sistema</h2>
            </div>
            <div class="cfg-card-body">
                <div class="cfg-stats">

                    <div class="cfg-stat">
                        <div class="cfg-stat-icon" style="background:#eff6ff;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                                <circle cx="9" cy="7" r="4"/>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                            </svg>
                        </div>
                        <div class="cfg-stat-body">
                            <div class="cfg-stat-value">@_totalUsuarios</div>
                            <div class="cfg-stat-label">Usuarios activos</div>
                        </div>
                        <div class="cfg-stat-bar" style="background:linear-gradient(135deg,#3b82f6,#60a5fa)"></div>
                    </div>

                    <div class="cfg-stat">
                        <div class="cfg-stat-icon" style="background:#f0fdf4;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                            </svg>
                        </div>
                        <div class="cfg-stat-body">
                            <div class="cfg-stat-value">@_totalPacientes</div>
                            <div class="cfg-stat-label">Pacientes registrados</div>
                        </div>
                        <div class="cfg-stat-bar" style="background:linear-gradient(135deg,#22c55e,#4ade80)"></div>
                    </div>

                    <div class="cfg-stat">
                        <div class="cfg-stat-icon" style="background:#f5f3ff;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                                <line x1="16" y1="13" x2="8" y2="13"/>
                                <line x1="16" y1="17" x2="8" y2="17"/>
                            </svg>
                        </div>
                        <div class="cfg-stat-body">
                            <div class="cfg-stat-value">@_totalEventosAuditoria</div>
                            <div class="cfg-stat-label">Eventos auditoría (30 días)</div>
                        </div>
                        <div class="cfg-stat-bar" style="background:linear-gradient(135deg,#8b5cf6,#a78bfa)"></div>
                    </div>

                </div>
            </div>
        </div>

        <!-- ── Plataforma (full width) ── -->
        <div class="cfg-card cfg-card-full">
            <div class="cfg-card-head">
                <div class="cfg-card-head-icon cfg-icon-teal">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="3"/>
                        <path d="M19.07 4.93l-1.41 1.41M4.93 4.93l1.41 1.41M19.07 19.07l-1.41-1.41M4.93 19.07l1.41-1.41M12 2v2M12 20v2M2 12h2M20 12h2"/>
                    </svg>
                </div>
                <h2 class="cfg-card-title">Plataforma DataMedix</h2>
            </div>
            <div class="cfg-card-body">
                <div class="cfg-platform">
                    <div class="cfg-platform-row">
                        <span class="cfg-platform-key">Versión</span>
                        <span class="cfg-platform-val">
                            <span class="cfg-badge cfg-badge-blue">v2.0 — Motor de Reglas</span>
                        </span>
                    </div>
                    <div class="cfg-platform-row">
                        <span class="cfg-platform-key">Motor clínico</span>
                        <span class="cfg-platform-val">26 reglas configurables (EPO · Hierro · Alertas · Modificadores)</span>
                    </div>
                    <div class="cfg-platform-row">
                        <span class="cfg-platform-key">Protocolo</span>
                        <span class="cfg-platform-val">Guías KDIGO · Fórmula de Ganzoni · Zonas Hb g/dL</span>
                    </div>
                    <div class="cfg-platform-row">
                        <span class="cfg-platform-key">Entorno</span>
                        <span class="cfg-platform-val">
                            <span class="cfg-badge cfg-badge-green">Production</span>
                        </span>
                    </div>
                    <div class="cfg-platform-row">
                        <span class="cfg-platform-key">Soporte</span>
                        <span class="cfg-platform-val">
                            <a href="mailto:soporte@datamedix.app" class="cfg-link">soporte&#64;datamedix.app</a>
                        </span>
                    </div>
                </div>
            </div>
        </div>

    </div>
}

@code {
    private Guid _tenantId;
    private Guid _usuarioActualId;
    private Tenant? _tenant;
    private string _nombreEdit = "";
    private bool _cargando = true;
    private bool _guardando;
    private string _error = "";
    private string _exito = "";

    private int _totalUsuarios;
    private int _totalPacientes;
    private int _totalEventosAuditoria;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var tenantStr = auth.User.FindFirst("tenant_id")?.Value;
        var userStr = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        _tenantId = Guid.TryParse(tenantStr, out var t) ? t : Guid.Empty;
        _usuarioActualId = Guid.TryParse(userStr, out var u) ? u : Guid.Empty;

        if (_tenantId != Guid.Empty)
            await CargarAsync();
        else
        {
            _error = "No se pudo determinar el tenant. Verifique su sesión.";
            _cargando = false;
        }
    }

    private async Task CargarAsync()
    {
        _cargando = true;
        _error = "";
        try
        {
            _tenant = await TenantRepo.GetByIdAsync(_tenantId);
            if (_tenant != null)
                _nombreEdit = _tenant.Nombre ?? "";

            _totalUsuarios = await UsuarioRepo.CountAsync(_tenantId, null);
            _totalPacientes = await PacienteRepo.CountAsync(_tenantId);
            _totalEventosAuditoria = await AuditoriaRepo.CountAsync(
                _tenantId, DateTime.UtcNow.Date.AddDays(-30), DateTime.UtcNow.Date, null, null);
        }
        catch (Exception ex)
        {
            _error = $"Error cargando configuración: {ex.Message}";
        }
        finally
        {
            _cargando = false;
        }
    }

    private async Task GuardarNombreAsync()
    {
        if (string.IsNullOrWhiteSpace(_nombreEdit))
        {
            _error = "El nombre del centro es obligatorio.";
            return;
        }
        _guardando = true;
        _error = "";
        _exito = "";
        try
        {
            await TenantRepo.UpdateNombreAsync(_tenantId, _nombreEdit.Trim());

            await AuditoriaRepo.RegistrarAsync(new AuditoriaLog
            {
                TenantId = _tenantId,
                UsuarioId = _usuarioActualId,
                Accion = "UPDATE",
                Entidad = "Tenant",
                EntidadId = _tenantId,
                Descripcion = $"Nombre del centro actualizado: {_nombreEdit.Trim()}"
            });

            _exito = "Nombre del centro actualizado correctamente.";
            if (_tenant != null) _tenant.Nombre = _nombreEdit.Trim();
        }
        catch (Exception ex)
        {
            _error = $"Error al guardar: {ex.Message}";
        }
        finally
        {
            _guardando = false;
        }
    }
}

<style>
    /* ── Layout ── */
    .cfg-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.75rem;
    }
    .cfg-header-icon {
        width: 44px; height: 44px;
        border-radius: 12px;
        background: linear-gradient(135deg, #0ea5e9, #8b5cf6);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 4px 14px rgba(14,165,233,0.35);
    }
    .cfg-header-icon svg { width: 22px; height: 22px; }
    .cfg-title { font-size: 1.6rem; font-weight: 900; color: #0f172a; margin: 0; line-height: 1.2; }
    .cfg-subtitle { font-size: 0.875rem; color: #94a3b8; margin: 0.15rem 0 0; }

    /* ── Banners ── */
    .cfg-banner {
        display: flex; align-items: center; gap: 0.625rem;
        border-radius: 10px; padding: 0.75rem 1rem;
        font-size: 0.875rem; font-weight: 500; margin-bottom: 1rem;
    }
    .cfg-banner-error  { background: #fef2f2; border: 1px solid #fecaca; color: #dc2626; }
    .cfg-banner-success{ background: #f0fdf4; border: 1px solid #86efac; color: #15803d; }

    /* ── Loading ── */
    .cfg-loading {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        padding: 4rem 0; gap: 1rem; color: #94a3b8;
    }
    .cfg-spinner {
        width: 36px; height: 36px;
        border: 3px solid #e2e8f0;
        border-top-color: #0ea5e9;
        border-radius: 50%;
        animation: cfg-spin 0.75s linear infinite;
    }
    @@keyframes cfg-spin { to { transform: rotate(360deg); } }

    /* ── Grid ── */
    .cfg-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.25rem;
    }
    .cfg-card-full { grid-column: 1 / -1; }

    /* ── Card ── */
    .cfg-card {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0,0,0,0.04);
        display: flex; flex-direction: column;
    }
    .cfg-card-head {
        display: flex; align-items: center; gap: 0.75rem;
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #f1f5f9;
        background: #f8fafc;
    }
    .cfg-card-head-icon {
        width: 32px; height: 32px; border-radius: 9px;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .cfg-card-head-icon svg { width: 16px; height: 16px; }
    .cfg-icon-blue   { background: linear-gradient(135deg, #0ea5e9, #38bdf8); }
    .cfg-icon-purple { background: linear-gradient(135deg, #8b5cf6, #a78bfa); }
    .cfg-icon-teal   { background: linear-gradient(135deg, #0d9488, #2dd4bf); }
    .cfg-card-title { font-size: 0.92rem; font-weight: 700; color: #0f172a; margin: 0; }
    .cfg-card-body { padding: 1.25rem; flex: 1; }

    /* ── Form ── */
    .cfg-field { display: flex; flex-direction: column; gap: 0.3rem; margin-bottom: 1.1rem; }
    .cfg-label { font-size: 0.8rem; font-weight: 700; color: #374151; }
    .cfg-required { color: #ef4444; margin-left: 0.15rem; }
    .cfg-hint { font-size: 0.75rem; color: #94a3b8; margin: 0; }
    .cfg-input {
        width: 100%;
        border: 1.5px solid #e2e8f0;
        border-radius: 9px;
        padding: 0.575rem 0.875rem;
        font-size: 0.875rem;
        color: #0f172a;
        background: white;
        outline: none;
        transition: border-color 0.15s, box-shadow 0.15s;
    }
    .cfg-input:focus {
        border-color: #0ea5e9;
        box-shadow: 0 0 0 3px rgba(14,165,233,0.12);
    }
    .cfg-input-readonly {
        display: flex; align-items: center; gap: 0;
        border: 1.5px solid #e2e8f0; border-radius: 9px;
        overflow: hidden; background: #f8fafc;
    }
    .cfg-subdomain-slug {
        padding: 0.575rem 0.875rem;
        font-size: 0.875rem; color: #374151; font-weight: 600;
        font-family: monospace;
    }
    .cfg-subdomain-suffix {
        padding: 0.575rem 0.875rem;
        font-size: 0.875rem; color: #94a3b8;
        background: #f1f5f9; border-left: 1px solid #e2e8f0;
        font-family: monospace;
    }
    .cfg-status {
        display: inline-flex; align-items: center; gap: 0.45rem;
        font-size: 0.875rem; font-weight: 600;
        padding: 0.35rem 0.75rem;
        border-radius: 8px;
    }
    .cfg-status-active   { background: #f0fdf4; color: #15803d; }
    .cfg-status-inactive { background: #f8fafc; color: #64748b; }
    .cfg-status-dot {
        width: 8px; height: 8px; border-radius: 50%;
    }
    .cfg-dot-active   { background: #22c55e; box-shadow: 0 0 0 3px rgba(34,197,94,0.2); animation: cfg-pulse 2s infinite; }
    .cfg-dot-inactive { background: #94a3b8; }
    @@keyframes cfg-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(34,197,94,0.4); }
        50%       { box-shadow: 0 0 0 5px rgba(34,197,94,0); }
    }
    .cfg-actions { padding-top: 1rem; border-top: 1px solid #f1f5f9; margin-top: 0.5rem; }
    .cfg-btn-save {
        display: inline-flex; align-items: center; gap: 0.5rem;
        background: linear-gradient(135deg, #0ea5e9, #0284c7);
        color: white; border: none; border-radius: 9px;
        padding: 0.6rem 1.25rem;
        font-size: 0.875rem; font-weight: 700;
        cursor: pointer; transition: all 0.15s;
        box-shadow: 0 2px 8px rgba(14,165,233,0.3);
    }
    .cfg-btn-save:hover:not(:disabled) {
        background: linear-gradient(135deg, #0284c7, #0369a1);
        box-shadow: 0 4px 14px rgba(14,165,233,0.4);
        transform: translateY(-1px);
    }
    .cfg-btn-save:disabled { opacity: 0.65; cursor: not-allowed; transform: none; }
    .cfg-btn-spinner {
        width: 14px; height: 14px;
        border: 2px solid rgba(255,255,255,0.4);
        border-top-color: white;
        border-radius: 50%;
        animation: cfg-spin 0.75s linear infinite;
    }

    /* ── Stats ── */
    .cfg-stats { display: flex; flex-direction: column; gap: 0.875rem; }
    .cfg-stat {
        display: flex; align-items: center; gap: 0.875rem;
        padding: 0.875rem;
        background: #f8fafc; border: 1px solid #f1f5f9;
        border-radius: 10px; position: relative; overflow: hidden;
    }
    .cfg-stat-icon {
        width: 44px; height: 44px; border-radius: 11px;
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .cfg-stat-body { flex: 1; min-width: 0; }
    .cfg-stat-value { font-size: 1.5rem; font-weight: 900; color: #0f172a; line-height: 1.1; }
    .cfg-stat-label { font-size: 0.78rem; color: #64748b; margin-top: 0.1rem; }
    .cfg-stat-bar {
        position: absolute; right: 0; top: 0; bottom: 0;
        width: 4px; border-radius: 0 10px 10px 0;
    }

    /* ── Platform ── */
    .cfg-platform { display: flex; flex-direction: column; }
    .cfg-platform-row {
        display: flex; align-items: center; gap: 1.5rem;
        padding: 0.75rem 0; border-bottom: 1px solid #f8fafc;
    }
    .cfg-platform-row:last-child { border-bottom: none; }
    .cfg-platform-key {
        font-size: 0.8rem; font-weight: 700; color: #64748b;
        width: 130px; flex-shrink: 0;
    }
    .cfg-platform-val { font-size: 0.875rem; color: #0f172a; }

    /* ── Badges ── */
    .cfg-badge {
        display: inline-flex; align-items: center;
        padding: 0.2rem 0.65rem; border-radius: 999px;
        font-size: 0.72rem; font-weight: 700;
    }
    .cfg-badge-blue  { background: #eff6ff; color: #1d4ed8; }
    .cfg-badge-green { background: #f0fdf4; color: #15803d; }
    .cfg-link { color: #0ea5e9; text-decoration: none; }
    .cfg-link:hover { text-decoration: underline; }

    @@media (max-width: 768px) {
        .cfg-grid { grid-template-columns: 1fr; }
        .cfg-card-full { grid-column: 1; }
        .cfg-platform-row { flex-direction: column; align-items: flex-start; gap: 0.25rem; }
        .cfg-platform-key { width: auto; }
    }
</style>
