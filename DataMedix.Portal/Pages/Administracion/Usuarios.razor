@page "/usuarios"
@attribute [Authorize(Roles = "SUPERADMIN,ADMIN")]
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using DataMedix.Application.Interfaces
@using DataMedix.Domain.Entities

@inject AuthenticationStateProvider AuthState
@inject IUsuarioRepository UsuarioRepo
@inject IAuditoriaRepository AuditoriaRepo

<PageTitle>Usuarios | DataMedix</PageTitle>

<!-- Header -->
<div class="usr-header">
    <div>
        <h1 class="usr-title">Usuarios</h1>
        <p class="usr-subtitle">Gestión de accesos al sistema · <strong>@_total</strong> usuario(s)</p>
    </div>
    <button class="usr-btn usr-btn-primary" @onclick="AbrirModalCrear">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Nuevo Usuario
    </button>
</div>

<!-- Toasts -->
@if (!string.IsNullOrEmpty(_error))
{
    <div class="usr-toast usr-toast-error">
        <span>⚠</span> @_error
        <button @onclick="() => _error = string.Empty">✕</button>
    </div>
}
@if (!string.IsNullOrEmpty(_exito))
{
    <div class="usr-toast usr-toast-success">
        <span>✓</span> @_exito
        <button @onclick="() => _exito = string.Empty">✕</button>
    </div>
}

<!-- Barra de búsqueda -->
<div class="usr-toolbar">
    <div class="usr-search-wrap">
        <svg class="usr-search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input class="usr-search-input" type="text"
               placeholder="Buscar por nombre, email o identificación..."
               @bind="_busqueda" @bind:event="oninput"
               @onkeyup="@(async e => { if (e.Key == "Enter") await BuscarAsync(); })" />
        @if (!string.IsNullOrEmpty(_busqueda))
        {
            <button class="usr-search-clear" @onclick="LimpiarAsync">✕</button>
        }
    </div>
    <button class="usr-btn usr-btn-outline" @onclick="BuscarAsync">Buscar</button>
</div>

<!-- Contenido -->
@if (_cargando)
{
    <div class="usr-loading">
        <div class="usr-spinner"></div>
        <p>Cargando usuarios...</p>
    </div>
}
else if (!_usuarios.Any())
{
    <div class="usr-empty">
        <div class="usr-empty-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
            </svg>
        </div>
        <p class="usr-empty-title">No se encontraron usuarios</p>
        <p class="usr-empty-desc">@(string.IsNullOrEmpty(_busqueda) ? "Crea el primer usuario con el botón + Nuevo Usuario." : $"No hay resultados para \"{_busqueda}\".")</p>
    </div>
}
else
{
    <!-- Tabla -->
    <div class="usr-table-card">
        <table class="usr-table">
            <thead>
                <tr>
                    <th>Usuario</th>
                    <th>Email</th>
                    <th>Identificación</th>
                    <th>Rol</th>
                    <th>Estado</th>
                    <th>Último Acceso</th>
                    <th style="width:90px;text-align:center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in _usuarios)
                {
                    var rolNombre = u.Roles.FirstOrDefault(r => r.Activo && r.TenantId == _tenantId)?.Rol?.Nombre
                                   ?? u.Roles.FirstOrDefault(r => r.Activo)?.Rol?.Nombre
                                   ?? "—";
                    <tr class="@(!u.Activo ? "usr-row-dim" : "")">
                        <td>
                            <div class="usr-user-cell">
                                <div class="usr-avatar">@(u.PrimerNombre?.FirstOrDefault())</div>
                                <div>
                                    <div class="usr-fullname">@u.NombreCompleto</div>
                                </div>
                            </div>
                        </td>
                        <td><span class="usr-mono">@u.Email</span></td>
                        <td><span class="usr-mono">@u.Identificacion</span></td>
                        <td><span class="usr-role-badge usr-role-@rolNombre.ToLower()">@rolNombre</span></td>
                        <td>
                            @if (u.Activo)
                            {
                                <span class="usr-status usr-status-active">
                                    <span class="usr-status-dot"></span> Activo
                                </span>
                            }
                            else
                            {
                                <span class="usr-status usr-status-inactive">
                                    <span class="usr-status-dot"></span> Inactivo
                                </span>
                            }
                        </td>
                        <td class="usr-muted">
                            @(u.UltimoAcceso.HasValue
                                ? u.UltimoAcceso.Value.ToLocalTime().ToString("dd/MM/yy HH:mm")
                                : "Nunca")
                        </td>
                        <td>
                            <div class="usr-actions">
                                <button class="usr-action-btn" title="Editar usuario" @onclick="() => AbrirModalEditar(u)">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                    </svg>
                                </button>
                                <button class="usr-action-btn @(u.Activo ? "usr-action-danger" : "usr-action-success")"
                                        title="@(u.Activo ? "Desactivar usuario" : "Activar usuario")"
                                        @onclick="() => ToggleActivoAsync(u)">
                                    @if (u.Activo)
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                                        </svg>
                                    }
                                    else
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                            <path d="M7 11V7a5 5 0 0 1 9.9-1"/>
                                        </svg>
                                    }
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Paginación -->
    @if (_totalPaginas > 1)
    {
        <div class="usr-pagination">
            <button class="usr-btn usr-btn-ghost" disabled="@(_pagina <= 1)"
                    @onclick="() => CambiarPaginaAsync(_pagina - 1)">← Anterior</button>
            <span class="usr-page-info">Página @_pagina de @_totalPaginas</span>
            <button class="usr-btn usr-btn-ghost" disabled="@(_pagina >= _totalPaginas)"
                    @onclick="() => CambiarPaginaAsync(_pagina + 1)">Siguiente →</button>
        </div>
    }
}

<!-- Modal Crear / Editar -->
@if (_modalAbierto)
{
    <div class="usr-backdrop" @onclick="CerrarModal">
        <div class="usr-modal" @onclick:stopPropagation="true">

            <div class="usr-modal-head">
                <div class="usr-modal-head-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                </div>
                <div>
                    <h3 class="usr-modal-title">@(_editando == null ? "Nuevo Usuario" : "Editar Usuario")</h3>
                    <p class="usr-modal-sub">@(_editando == null ? "Ingrese los datos del nuevo acceso" : $"Editando: {_editando.Email}")</p>
                </div>
                <button class="usr-modal-close" @onclick="CerrarModal">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>
            </div>

            <div class="usr-modal-body">
                @if (!string.IsNullOrEmpty(_modalError))
                {
                    <div class="usr-toast usr-toast-error" style="margin-bottom:1rem">
                        <span>⚠</span> @_modalError
                    </div>
                }

                <div class="usr-field-row">
                    <div class="usr-field">
                        <label class="usr-label">Primer Nombre <span class="usr-req">*</span></label>
                        <input class="usr-input" @bind="_form.PrimerNombre" placeholder="Ej: Juan" />
                    </div>
                    <div class="usr-field">
                        <label class="usr-label">Segundo Nombre</label>
                        <input class="usr-input" @bind="_form.SegundoNombre" placeholder="Opcional" />
                    </div>
                </div>
                <div class="usr-field-row">
                    <div class="usr-field">
                        <label class="usr-label">Primer Apellido <span class="usr-req">*</span></label>
                        <input class="usr-input" @bind="_form.PrimerApellido" placeholder="Ej: Pérez" />
                    </div>
                    <div class="usr-field">
                        <label class="usr-label">Segundo Apellido</label>
                        <input class="usr-input" @bind="_form.SegundoApellido" placeholder="Opcional" />
                    </div>
                </div>
                <div class="usr-field-row">
                    <div class="usr-field">
                        <label class="usr-label">Identificación <span class="usr-req">*</span></label>
                        <input class="usr-input" @bind="_form.Identificacion" placeholder="Cédula o pasaporte" />
                    </div>
                    <div class="usr-field">
                        <label class="usr-label">Teléfono</label>
                        <input class="usr-input" @bind="_form.Telefono" placeholder="Ej: 0999123456" />
                    </div>
                </div>
                <div class="usr-field">
                    <label class="usr-label">Correo Electrónico <span class="usr-req">*</span></label>
                    <input class="usr-input" type="email" @bind="_form.Email" placeholder="usuario@clinica.com" />
                </div>

                @if (_editando == null)
                {
                    <div class="usr-field">
                        <label class="usr-label">Contraseña <span class="usr-req">*</span></label>
                        <input class="usr-input" type="password" @bind="_form.Password" placeholder="Mínimo 6 caracteres" />
                    </div>
                    <div class="usr-field">
                        <label class="usr-label">Rol <span class="usr-req">*</span></label>
                        <select class="usr-input usr-select" @bind="_form.RolId">
                            <option value="">— Seleccionar rol —</option>
                            @foreach (var rol in _rolesDisponibles)
                            {
                                <option value="@rol.Id">@rol.Nombre · @DescripcionRol(rol.Nombre)</option>
                            }
                        </select>
                    </div>
                }
            </div>

            <div class="usr-modal-foot">
                <button class="usr-btn usr-btn-ghost" @onclick="CerrarModal">Cancelar</button>
                <button class="usr-btn usr-btn-primary" @onclick="GuardarAsync" disabled="@_guardando">
                    @if (_guardando)
                    {
                        <span class="usr-spinner-sm"></span>
                        <span>Guardando...</span>
                    }
                    else
                    {
                        <span>@(_editando == null ? "Crear Usuario" : "Guardar Cambios")</span>
                    }
                </button>
            </div>

        </div>
    </div>
}

@code {
    private Guid _tenantId;
    private Guid _usuarioActualId;
    private List<Usuario> _usuarios = [];
    private List<Rol> _rolesDisponibles = [];
    private int _total;
    private int _pagina = 1;
    private const int _tamano = 20;
    private int _totalPaginas => (int)Math.Ceiling((double)_total / _tamano);
    private string _busqueda = "";
    private bool _cargando = true;
    private string _error = "";
    private string _exito = "";

    private bool _modalAbierto;
    private Usuario? _editando;
    private UsuarioFormModel _form = new();
    private bool _guardando;
    private string _modalError = "";

    private record UsuarioFormModel
    {
        public string PrimerNombre  { get; set; } = "";
        public string? SegundoNombre { get; set; }
        public string PrimerApellido { get; set; } = "";
        public string? SegundoApellido { get; set; }
        public string Identificacion { get; set; } = "";
        public string? Telefono { get; set; }
        public string Email    { get; set; } = "";
        public string Password { get; set; } = "";
        public string Codigo   { get; set; } = "";
        public string RolId    { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _tenantId       = Guid.TryParse(auth.User.FindFirst("tenant_id")?.Value,         out var t) ? t : Guid.Empty;
        _usuarioActualId = Guid.TryParse(auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var u) ? u : Guid.Empty;

        if (_tenantId != Guid.Empty)
        {
            _rolesDisponibles = await UsuarioRepo.GetRolesDisponiblesAsync();
            await CargarAsync();
        }
        else
        {
            _error = "No se pudo determinar el tenant. Verifique su sesión.";
            _cargando = false;
        }
    }

    private async Task CargarAsync()
    {
        _cargando = true; _error = "";
        try
        {
            _total    = await UsuarioRepo.CountAsync(_tenantId, _busqueda);
            _usuarios = await UsuarioRepo.GetByTenantAsync(_tenantId, _busqueda, _pagina, _tamano);
        }
        catch (Exception ex) { _error = $"Error cargando usuarios: {ex.Message}"; }
        finally { _cargando = false; }
    }

    private async Task BuscarAsync()  { _pagina = 1; await CargarAsync(); }
    private async Task LimpiarAsync() { _busqueda = ""; _pagina = 1; await CargarAsync(); }
    private async Task CambiarPaginaAsync(int p) { _pagina = p; await CargarAsync(); }

    private void AbrirModalCrear()
    {
        _editando = null; _form = new(); _modalError = ""; _modalAbierto = true;
    }

    private void AbrirModalEditar(Usuario u)
    {
        _editando = u;
        _form = new()
        {
            PrimerNombre   = u.PrimerNombre,
            SegundoNombre  = u.SegundoNombre,
            PrimerApellido = u.PrimerApellido,
            SegundoApellido = u.SegundoApellido,
            Identificacion = u.Identificacion,
            Telefono       = u.Telefono,
            Email          = u.Email,
            Codigo         = u.Codigo
        };
        _modalError = ""; _modalAbierto = true;
    }

    private void CerrarModal() => _modalAbierto = false;

    private async Task GuardarAsync()
    {
        _modalError = "";
        if (string.IsNullOrWhiteSpace(_form.PrimerNombre) ||
            string.IsNullOrWhiteSpace(_form.PrimerApellido) ||
            string.IsNullOrWhiteSpace(_form.Identificacion) ||
            string.IsNullOrWhiteSpace(_form.Email))
        { _modalError = "Los campos marcados con * son obligatorios."; return; }

        if (_editando == null)
        {
            if (string.IsNullOrWhiteSpace(_form.Password) || _form.Password.Length < 6)
            { _modalError = "La contraseña debe tener al menos 6 caracteres."; return; }
            if (!Guid.TryParse(_form.RolId, out var rolId))
            { _modalError = "Seleccione un rol para el usuario."; return; }

            _guardando = true;
            try
            {
                var nuevo = new Usuario
                {
                    Id = Guid.NewGuid(), TenantId = _tenantId,
                    Codigo = string.IsNullOrWhiteSpace(_form.Codigo)
                        ? $"USR-{DateTime.UtcNow:yyyyMMddHHmmss}" : _form.Codigo,
                    Identificacion = _form.Identificacion.Trim(),
                    PrimerNombre   = _form.PrimerNombre.Trim(),
                    SegundoNombre  = _form.SegundoNombre?.Trim(),
                    PrimerApellido = _form.PrimerApellido.Trim(),
                    SegundoApellido = _form.SegundoApellido?.Trim(),
                    Email    = _form.Email.Trim().ToLowerInvariant(),
                    Telefono = _form.Telefono?.Trim(),
                    Activo   = true, CreatedBy = _usuarioActualId, PasswordHash = ""
                };
                await UsuarioRepo.AddAsync(nuevo, _form.Password, rolId);
                await AuditoriaRepo.RegistrarAsync(new AuditoriaLog
                {
                    TenantId = _tenantId, UsuarioId = _usuarioActualId,
                    Accion = "CREATE", Entidad = "Usuario", EntidadId = nuevo.Id,
                    Descripcion = $"Usuario creado: {nuevo.Email}"
                });
                _exito = $"Usuario {nuevo.NombreCompleto} creado correctamente.";
                _modalAbierto = false;
                await CargarAsync();
            }
            catch (Exception ex)
            {
                _modalError = ex.Message.Contains("unique") || ex.Message.Contains("duplicate")
                    ? "Ya existe un usuario con ese correo electrónico."
                    : $"Error al crear usuario: {ex.Message}";
            }
            finally { _guardando = false; }
        }
        else
        {
            _guardando = true;
            try
            {
                _editando.PrimerNombre    = _form.PrimerNombre.Trim();
                _editando.SegundoNombre   = _form.SegundoNombre?.Trim();
                _editando.PrimerApellido  = _form.PrimerApellido.Trim();
                _editando.SegundoApellido = _form.SegundoApellido?.Trim();
                _editando.Identificacion  = _form.Identificacion.Trim();
                _editando.Telefono        = _form.Telefono?.Trim();
                _editando.Email           = _form.Email.Trim().ToLowerInvariant();
                _editando.Codigo          = string.IsNullOrWhiteSpace(_form.Codigo) ? _editando.Codigo : _form.Codigo;

                await UsuarioRepo.UpdateAsync(_editando);
                await AuditoriaRepo.RegistrarAsync(new AuditoriaLog
                {
                    TenantId = _tenantId, UsuarioId = _usuarioActualId,
                    Accion = "UPDATE", Entidad = "Usuario", EntidadId = _editando.Id,
                    Descripcion = $"Usuario editado: {_editando.Email}"
                });
                _exito = "Cambios guardados correctamente.";
                _modalAbierto = false;
                await CargarAsync();
            }
            catch (Exception ex)
            {
                _modalError = ex.Message.Contains("unique") || ex.Message.Contains("duplicate")
                    ? "Ya existe un usuario con ese correo electrónico."
                    : $"Error al guardar: {ex.Message}";
            }
            finally { _guardando = false; }
        }
    }

    private async Task ToggleActivoAsync(Usuario u)
    {
        if (u.Id == _usuarioActualId) { _error = "No puede desactivar su propio usuario."; return; }
        _error = "";
        try
        {
            u.Activo = !u.Activo;
            await UsuarioRepo.UpdateAsync(u);
            await AuditoriaRepo.RegistrarAsync(new AuditoriaLog
            {
                TenantId = _tenantId, UsuarioId = _usuarioActualId,
                Accion = u.Activo ? "UPDATE" : "DELETE", Entidad = "Usuario", EntidadId = u.Id,
                Descripcion = $"Usuario {(u.Activo ? "activado" : "desactivado")}: {u.Email}"
            });
            _exito = $"Usuario {(u.Activo ? "activado" : "desactivado")} correctamente.";
            await CargarAsync();
        }
        catch (Exception ex) { u.Activo = !u.Activo; _error = $"Error: {ex.Message}"; }
    }

    private static string DescripcionRol(string rol) => rol switch
    {
        "ADMIN"        => "Administrador",
        "MEDICO"       => "Médico",
        "OPERADOR"     => "Operador",
        "VISUALIZADOR" => "Solo lectura",
        _              => ""
    };
}

<style>
    /* ── Layout ────────────────────────────────────────────── */
    .usr-header {
        display: flex; align-items: flex-start;
        justify-content: space-between; gap: 1rem;
        margin-bottom: 1.5rem; flex-wrap: wrap;
    }
    .usr-title {
        font-size: 1.6rem; font-weight: 800;
        color: #0f172a; margin: 0; letter-spacing: -0.03em;
    }
    .usr-subtitle { color: #64748b; margin: 0.2rem 0 0; font-size: 0.875rem; }

    /* ── Toasts ────────────────────────────────────────────── */
    .usr-toast {
        display: flex; align-items: center; gap: 0.625rem;
        padding: 0.75rem 1rem; border-radius: 10px;
        font-size: 0.875rem; font-weight: 500;
        margin-bottom: 1rem; border: 1px solid;
    }
    .usr-toast button {
        margin-left: auto; background: none; border: none;
        cursor: pointer; color: inherit; font-size: 0.9rem; padding: 0;
    }
    .usr-toast-error   { background: #fef2f2; border-color: #fecaca; color: #b91c1c; }
    .usr-toast-success { background: #f0fdf4; border-color: #bbf7d0; color: #15803d; }

    /* ── Toolbar ───────────────────────────────────────────── */
    .usr-toolbar {
        display: flex; align-items: center; gap: 0.75rem;
        margin-bottom: 1.25rem; flex-wrap: wrap;
    }
    .usr-search-wrap {
        flex: 1; min-width: 260px; position: relative; display: flex; align-items: center;
    }
    .usr-search-icon {
        position: absolute; left: 0.875rem;
        width: 16px; height: 16px; color: #94a3b8; pointer-events: none;
    }
    .usr-search-input {
        width: 100%; padding: 0.6rem 2.5rem 0.6rem 2.5rem;
        border: 1.5px solid #e2e8f0; border-radius: 10px;
        font-size: 0.875rem; background: white; color: #1e293b;
        transition: border-color 0.15s, box-shadow 0.15s;
        outline: none;
    }
    .usr-search-input:focus {
        border-color: #0ea5e9;
        box-shadow: 0 0 0 3px rgba(14,165,233,0.12);
    }
    .usr-search-clear {
        position: absolute; right: 0.75rem;
        background: none; border: none; cursor: pointer;
        color: #94a3b8; font-size: 0.85rem; padding: 0.2rem;
    }
    .usr-search-clear:hover { color: #475569; }

    /* ── Buttons ───────────────────────────────────────────── */
    .usr-btn {
        display: inline-flex; align-items: center; gap: 0.4rem;
        padding: 0.575rem 1.1rem; border-radius: 9px;
        font-size: 0.875rem; font-weight: 600; cursor: pointer;
        border: 1.5px solid transparent; transition: all 0.15s;
        white-space: nowrap; text-decoration: none;
    }
    .usr-btn:disabled { opacity: 0.6; cursor: not-allowed; }
    .usr-btn-primary  { background: #0ea5e9; color: white; border-color: #0ea5e9; }
    .usr-btn-primary:hover:not(:disabled) { background: #0284c7; border-color: #0284c7; }
    .usr-btn-outline  { background: white; color: #374151; border-color: #d1d5db; }
