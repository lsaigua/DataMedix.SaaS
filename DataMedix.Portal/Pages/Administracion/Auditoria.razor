@page "/auditoria"
@attribute [Authorize(Roles = "SUPERADMIN,ADMIN")]
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using DataMedix.Application.Interfaces
@using DataMedix.Domain.Entities

@inject AuthenticationStateProvider AuthState
@inject IAuditoriaRepository AuditoriaRepo
@inject IUsuarioRepository UsuarioRepo

<PageTitle>Auditoría | DataMedix</PageTitle>

<!-- Header -->
<div class="aud-header">
    <div class="aud-header-icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
             stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
        </svg>
    </div>
    <div>
        <h1 class="aud-title">Auditoría</h1>
        <p class="aud-subtitle">Registro de actividad del sistema — <strong>@_total</strong> evento(s)</p>
    </div>
</div>

@if (!string.IsNullOrEmpty(_error))
{
    <div class="aud-banner-error">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        @_error
    </div>
}

<!-- Filtros -->
<div class="aud-filters">
    <div class="aud-filter-group">
        <label class="aud-filter-label">Desde</label>
        <input class="aud-filter-input" type="date" @bind="_desde" />
    </div>
    <div class="aud-filter-group">
        <label class="aud-filter-label">Hasta</label>
        <input class="aud-filter-input" type="date" @bind="_hasta" />
    </div>
    <div class="aud-filter-group">
        <label class="aud-filter-label">Acción</label>
        <select class="aud-filter-input" @bind="_accionFiltro">
            <option value="">Todas</option>
            <option value="LOGIN">LOGIN</option>
            <option value="LOGOUT">LOGOUT</option>
            <option value="IMPORT">IMPORT</option>
            <option value="CREATE">CREATE</option>
            <option value="UPDATE">UPDATE</option>
            <option value="DELETE">DELETE</option>
            <option value="APPROVE">APPROVE</option>
            <option value="EXPORT">EXPORT</option>
        </select>
    </div>
    <div class="aud-filter-actions">
        <button class="aud-btn aud-btn-primary" @onclick="BuscarAsync">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            Aplicar
        </button>
        <button class="aud-btn aud-btn-ghost" @onclick="LimpiarAsync">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            Limpiar
        </button>
    </div>
</div>

@if (_cargando)
{
    <div class="aud-loading">
        <div class="aud-spinner"></div>
        <p>Cargando registros...</p>
    </div>
}
else if (!_logs.Any())
{
    <div class="aud-empty">
        <div class="aud-empty-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
            </svg>
        </div>
        <p class="aud-empty-text">No se encontraron eventos con los filtros aplicados.</p>
        <button class="aud-btn aud-btn-ghost" @onclick="LimpiarAsync">Ver todos los eventos</button>
    </div>
}
else
{
    <div class="aud-table-card">
        <!-- Cabecera de tabla -->
        <div class="aud-table-wrap">
            <table class="aud-table">
                <thead>
                    <tr>
                        <th>Fecha / Hora</th>
                        <th>Acción</th>
                        <th>Entidad</th>
                        <th>Descripción</th>
                        <th>Resultado</th>
                        <th>IP</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in _logs)
                    {
                        <tr>
                            <td>
                                <div class="aud-fecha-date">@log.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</div>
                                <div class="aud-fecha-time">@log.CreatedAt.ToLocalTime().ToString("HH:mm:ss")</div>
                            </td>
                            <td>
                                <span class="aud-accion aud-accion-@log.Accion.ToLower()">@log.Accion</span>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(log.Entidad))
                                {
                                    <span class="aud-entidad-badge">@log.Entidad</span>
                                }
                            </td>
                            <td class="aud-desc">
                                @log.Descripcion
                                @if (!string.IsNullOrEmpty(log.MensajeError))
                                {
                                    <div class="aud-error-msg">@log.MensajeError</div>
                                }
                            </td>
                            <td>
                                @if (log.Resultado == "OK")
                                {
                                    <span class="aud-resultado aud-resultado-ok">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                                        OK
                                    </span>
                                }
                                else
                                {
                                    <span class="aud-resultado aud-resultado-err">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                        ERROR
                                    </span>
                                }
                            </td>
                            <td class="aud-ip">@(log.IpAddress ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Paginación -->
        @if (_totalPaginas > 1)
        {
            <div class="aud-pagination">
                <button class="aud-page-btn" disabled="@(_pagina <= 1)"
                        @onclick="() => CambiarPaginaAsync(_pagina - 1)">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
                    Anterior
                </button>
                <span class="aud-page-info">
                    Página <strong>@_pagina</strong> de <strong>@_totalPaginas</strong>
                    <span class="aud-page-total">(@_total eventos)</span>
                </span>
                <button class="aud-page-btn" disabled="@(_pagina >= _totalPaginas)"
                        @onclick="() => CambiarPaginaAsync(_pagina + 1)">
                    Siguiente
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
            </div>
        }
    </div>
}

@code {
    private Guid _tenantId;
    private List<AuditoriaLog> _logs = [];
    private int _total;
    private int _pagina = 1;
    private const int _tamano = 30;
    private int _totalPaginas => (int)Math.Ceiling((double)_total / _tamano);
    private bool _cargando = true;
    private string _error = "";

    private DateTime? _desde;
    private DateTime? _hasta;
    private string _accionFiltro = "";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var tenantStr = auth.User.FindFirst("tenant_id")?.Value;
        _tenantId = Guid.TryParse(tenantStr, out var t) ? t : Guid.Empty;

        _hasta = DateTime.UtcNow.Date;
        _desde = DateTime.UtcNow.Date.AddDays(-30);

        if (_tenantId != Guid.Empty)
            await CargarAsync();
        else
        {
            _error = "No se pudo determinar el tenant. Verifique su sesión.";
            _cargando = false;
        }
    }

    private async Task CargarAsync()
    {
        _cargando = true;
        _error = "";
        try
        {
            var accion = string.IsNullOrWhiteSpace(_accionFiltro) ? null : _accionFiltro;
            _total = await AuditoriaRepo.CountAsync(_tenantId, _desde, _hasta, accion, null);
            _logs = await AuditoriaRepo.GetPagedAsync(_tenantId, _pagina, _tamano, _desde, _hasta, accion, null);
        }
        catch (Exception ex)
        {
            _error = $"Error cargando auditoría: {ex.Message}";
        }
        finally
        {
            _cargando = false;
        }
    }

    private async Task BuscarAsync()   { _pagina = 1; await CargarAsync(); }
    private async Task LimpiarAsync()
    {
        _accionFiltro = "";
        _hasta = DateTime.UtcNow.Date;
        _desde = DateTime.UtcNow.Date.AddDays(-30);
        _pagina = 1;
        await CargarAsync();
    }
    private async Task CambiarPaginaAsync(int pagina) { _pagina = pagina; await CargarAsync(); }
}

<style>
    /* ── Header ── */
    .aud-header {
        display: flex; align-items: center; gap: 1rem; margin-bottom: 1.75rem;
    }
    .aud-header-icon {
        width: 44px; height: 44px; border-radius: 12px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        display: flex; align-items: center; justify-content: center; flex-shrink: 0;
        box-shadow: 0 4px 14px rgba(99,102,241,0.35);
    }
    .aud-header-icon svg { width: 22px; height: 22px; }
    .aud-title { font-size: 1.6rem; font-weight: 900; color: #0f172a; margin: 0; line-height: 1.2; }
    .aud-subtitle { font-size: 0.875rem; color: #94a3b8; margin: 0.15rem 0 0; }

    /* ── Banner ── */
    .aud-banner-error {
        display: flex; align-items: center; gap: 0.5rem;
        background: #fef2f2; border: 1px solid #fecaca; border-radius: 10px;
        padding: 0.75rem 1rem; color: #dc2626; font-size: 0.875rem;
        margin-bottom: 1rem;
    }

    /* ── Filters ── */
    .aud-filters {
        display: flex; flex-wrap: wrap; align-items: flex-end; gap: 0.875rem;
        background: white; border: 1px solid #e2e8f0; border-radius: 12px;
        padding: 1rem 1.25rem; margin-bottom: 1.25rem;
        box-shadow: 0 1px 4px rgba(0,0,0,0.04);
    }
    .aud-filter-group { display: flex; flex-direction: column; gap: 0.25rem; }
    .aud-filter-label { font-size: 0.72rem; font-weight: 700; color: #374151; }
    .aud-filter-input {
        border: 1.5px solid #e2e8f0; border-radius: 8px;
        padding: 0.45rem 0.75rem; font-size: 0.82rem; color: #374151;
        background: white; outline: none; transition: border-color 0.15s, box-shadow 0.15s;
    }
    .aud-filter-input:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 3px rgba(99,102,241,0.1);
    }
    .aud-filter-actions { display: flex; gap: 0.5rem; align-items: flex-end; margin-left: auto; }

    /* ── Buttons ── */
    .aud-btn {
        display: inline-flex; align-items: center; gap: 0.4rem;
        border-radius: 8px; padding: 0.48rem 0.875rem;
        font-size: 0.82rem; font-weight: 700; cursor: pointer;
        transition: all 0.15s; border: none;
    }
    .aud-btn-primary {
        background: linear-gradient(135deg, #6366f1, #4f46e5);
        color: white;
        box-shadow: 0 2px 8px rgba(99,102,241,0.3);
    }
    .aud-btn-primary:hover { box-shadow: 0 4px 14px rgba(99,102,241,0.4); transform: translateY(-1px); }
    .aud-btn-ghost {
        background: white; color: #64748b;
        border: 1.5px solid #e2e8f0;
    }
    .aud-btn-ghost:hover { background: #f8fafc; color: #374151; }

    /* ── Loading ── */
    .aud-loading {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        padding: 4rem 0; gap: 1rem; color: #94a3b8;
    }
    .aud-spinner {
        width: 36px; height: 36px;
        border: 3px solid #e2e8f0; border-top-color: #6366f1;
        border-radius: 50%;
        animation: aud-spin 0.75s linear infinite;
    }
    @@keyframes aud-spin { to { transform: rotate(360deg); } }

    /* ── Empty ── */
    .aud-empty {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        padding: 4rem 0; gap: 0.75rem; text-align: center;
    }
    .aud-empty-icon {
        width: 64px; height: 64px; border-radius: 16px;
        background: #f8fafc; border: 1px solid #e2e8f0;
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 0.25rem;
    }
    .aud-empty-text { font-size: 0.9rem; color: #94a3b8; }

    /* ── Table card ── */
    .aud-table-card {
        background: white; border: 1px solid #e2e8f0;
        border-radius: 14px; overflow: hidden;
        box-shadow: 0 1px 4px rgba(0,0,0,0.04);
    }
    .aud-table-wrap { overflow-x: auto; }
    .aud-table {
        width: 100%; border-collapse: collapse; font-size: 0.845rem;
    }
    .aud-table thead tr {
        background: #f8fafc; border-bottom: 2px solid #e2e8f0;
    }
    .aud-table th {
        padding: 0.7rem 1rem; text-align: left;
        font-size: 0.72rem; font-weight: 700; color: #64748b;
        text-transform: uppercase; letter-spacing: 0.06em;
        white-space: nowrap;
    }
    .aud-table td { padding: 0.75rem 1rem; border-bottom: 1px solid #f1f5f9; vertical-align: top; }
    .aud-table tbody tr:last-child td { border-bottom: none; }
    .aud-table tbody tr:hover td { background: #fafbff; }

    .aud-fecha-date { font-weight: 700; font-size: 0.82rem; color: #0f172a; }
    .aud-fecha-time { font-size: 0.75rem; color: #94a3b8; margin-top: 0.1rem; }

    /* Acción badges */
    .aud-accion {
        display: inline-block;
        padding: 0.2rem 0.55rem; border-radius: 5px;
        font-size: 0.68rem; font-weight: 800;
        letter-spacing: 0.05em; text-transform: uppercase; white-space: nowrap;
    }
    .aud-accion-login, .aud-accion-logout { background: #eff6ff; color: #1d4ed8; }
    .aud-accion-import                    { background: #ecfdf5; color: #059669; }
    .aud-accion-create                    { background: #f0fdf4; color: #16a34a; }
    .aud-accion-update                    { background: #fffbeb; color: #b45309; }
    .aud-accion-delete                    { background: #fef2f2; color: #dc2626; }
    .aud-accion-approve                   { background: #f5f3ff; color: #7c3aed; }
    .aud-accion-export                    { background: #f0f9ff; color: #0369a1; }

    /* Entidad badge */
    .aud-entidad-badge {
        display: inline-block; padding: 0.15rem 0.55rem;
        background: #f1f5f9; color: #475569;
        border-radius: 5px; font-size: 0.72rem; font-weight: 600;
        white-space: nowrap;
    }

    .aud-desc { max-width: 300px; color: #374151; }
    .aud-error-msg { color: #dc2626; font-size: 0.76rem; margin-top: 0.2rem; }

    /* Resultado badges */
    .aud-resultado {
        display: inline-flex; align-items: center; gap: 0.3rem;
        padding: 0.18rem 0.55rem; border-radius: 5px;
        font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em;
        white-space: nowrap;
    }
    .aud-resultado-ok  { background: #f0fdf4; color: #16a34a; }
    .aud-resultado-err { background: #fef2f2; color: #dc2626; }

    .aud-ip { font-family: monospace; font-size: 0.78rem; color: #94a3b8; white-space: nowrap; }

    /* ── Pagination ── */
    .aud-pagination {
        display: flex; align-items: center; justify-content: center; gap: 1.25rem;
        padding: 1rem 1.25rem; border-top: 1px solid #f1f5f9;
        background: #fafbff;
    }
    .aud-page-btn {
        display: inline-flex; align-items: center; gap: 0.35rem;
        padding: 0.45rem 0.875rem; border-radius: 8px;
        background: white; border: 1.5px solid #e2e8f0;
        font-size: 0.82rem; font-weight: 600; color: #374151;
        cursor: pointer; transition: all 0.15s;
    }
    .aud-page-btn:hover:not(:disabled) { background: #f8fafc; border-color: #6366f1; color: #6366f1; }
    .aud-page-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .aud-page-info { font-size: 0.82rem; color: #64748b; }
    .aud-page-total { color: #94a3b8; margin-left: 0.35rem; }

    @@media (max-width: 768px) {
        .aud-filters { gap: 0.625rem; }
        .aud-filter-actions { margin-left: 0; }
        .aud-table th, .aud-table td { padding: 0.6rem 0.75rem; }
    }
</style>
