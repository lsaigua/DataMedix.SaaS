@code {
    private Dictionary<string, List<RangoPrescriba>> RangosPorParametro = new();
    private List<ParametroClinico> ParametrosClinicos = new();
    private bool Cargando = true;
    private bool MostrarModal = false;
    private bool Guardando = false;
    private string ErrorModal = string.Empty;
    private RangoPrescriba RangoEditando = new();
    private Guid TenantId;

    // Binding helpers para nullable decimals
    private string ValorMinimoStr
    {
        get => RangoEditando.ValorMinimo?.ToString("G6") ?? string.Empty;
        set => RangoEditando.ValorMinimo = decimal.TryParse(value, out var v) ? v : null;
    }
    private string ValorMaximoStr
    {
        get => RangoEditando.ValorMaximo?.ToString("G6") ?? string.Empty;
        set => RangoEditando.ValorMaximo = decimal.TryParse(value, out var v) ? v : null;
    }
    private string AjusteStr
    {
        get => RangoEditando.AjustePorcentaje?.ToString("F0") ?? string.Empty;
        set => RangoEditando.AjustePorcentaje = decimal.TryParse(value, out var v) ? v : null;
    }

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var tenantStr = auth.User.FindFirst("tenant_id")?.Value;
        TenantId = Guid.TryParse(tenantStr, out var t) ? t : Guid.Empty;
        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        Cargando = true;
        StateHasChanged();
        try
        {
            ParametrosClinicos = await ParametroRepo.GetAllAsync();
            var rangos = await RangoRepo.GetAllAsync(TenantId);
            RangosPorParametro = rangos
                .GroupBy(r => r.ParametroClinico?.Codigo ?? "?")
                .ToDictionary(g => g.Key, g => g.ToList());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando rangos: {ex.Message}");
        }
        finally
        {
            Cargando = false;
        }
    }

    private void AbrirNuevoRango()
    {
        RangoEditando = new RangoPrescriba { TenantId = TenantId, Orden = 50, Activo = true };
        ErrorModal = string.Empty;
        MostrarModal = true;
    }

    private void AbrirNuevoRangoParaParametro(string codigoParametro)
    {
        var param = ParametrosClinicos.FirstOrDefault(p => p.Codigo == codigoParametro);
        RangoEditando = new RangoPrescriba
        {
            TenantId = TenantId,
            ParametroClinicoId = param?.Id ?? Guid.Empty,
            Orden = 50,
            Activo = true
        };
        ErrorModal = string.Empty;
        MostrarModal = true;
    }

    private void EditarRango(RangoPrescriba rango)
    {
        // Clonar para no modificar la lista directamente
        RangoEditando = new RangoPrescriba
        {
            Id = rango.Id,
            TenantId = rango.TenantId,
            ParametroClinicoId = rango.ParametroClinicoId,
            Nombre = rango.Nombre,
            Descripcion = rango.Descripcion,
            ValorMinimo = rango.ValorMinimo,
            ValorMaximo = rango.ValorMaximo,
            Accion = rango.Accion,
            Medicamento = rango.Medicamento,
            DosisSugerida = rango.DosisSugerida,
            AjustePorcentaje = rango.AjustePorcentaje,
            Observacion = rango.Observacion,
            Orden = rango.Orden,
            VigenteDesdé = rango.VigenteDesdé,
            VigenteHasta = rango.VigenteHasta,
            Activo = rango.Activo
        };
        ErrorModal = string.Empty;
        MostrarModal = true;
    }

    private async Task GuardarRangoAsync()
    {
        ErrorModal = string.Empty;

        if (RangoEditando.ParametroClinicoId == Guid.Empty)
        { ErrorModal = "Seleccione un parámetro clínico."; return; }

        if (string.IsNullOrWhiteSpace(RangoEditando.Nombre))
        { ErrorModal = "El nombre del rango es requerido."; return; }

        if (string.IsNullOrWhiteSpace(RangoEditando.Accion))
        { ErrorModal = "Seleccione una acción."; return; }

        Guardando = true;
        try
        {
            await RangoRepo.UpsertAsync(RangoEditando);
            MostrarModal = false;
            await CargarAsync();
        }
        catch (Exception ex)
        {
            ErrorModal = $"Error al guardar: {ex.Message}";
        }
        finally
        {
            Guardando = false;
        }
    }

    private void CerrarModal()
    {
        MostrarModal = false;
        ErrorModal = string.Empty;
    }

    private static string ColorCodigo(string codigo) => codigo switch
    {
        "HB" => "dm-codigo-hb",
        "FE" => "dm-codigo-fe",
        "FERR" => "dm-codigo-ferr",
        "ISAT" => "dm-codigo-isat",
        _ => "dm-codigo-default"
    };

    private static string AccionClase(string accion) => accion switch
    {
        "AUMENTAR" => "dm-accion-aumentar",
        "MANTENER" => "dm-accion-mantener",
        "REDUCIR" => "dm-accion-reducir",
        "SUSPENDER" => "dm-accion-suspender",
        _ => "dm-accion-default"
    };

    private static string Truncate(string s, int max) =>
        s.Length > max ? s[..max] + "…" : s;
}
