@page "/rangos-prescriba"
@attribute [Authorize(Roles = "SUPERADMIN,ADMIN,MEDICO")]
@using Microsoft.AspNetCore.Authorization
@using DataMedix.Application.Interfaces
@using DataMedix.Domain.Entities
@using System.Security.Claims

@inject IRangoPreescribaRepository RangoRepo
@inject IParametroClinicoRepository ParametroRepo
@inject AuthenticationStateProvider AuthState

<PageTitle>Rangos a Prescribir | DataMedix</PageTitle>

<div class="dm-page-header">
    <div>
        <h1 class="dm-page-title">Rangos a Prescribir</h1>
        <p class="dm-page-subtitle">Reglas clínicas que guían el motor de prescripción de EPO y Hierro IV</p>
    </div>
    <div class="dm-page-actions">
        <button class="dm-btn dm-btn-primary" @onclick="AbrirNuevoRango" disabled="@(!ParametrosClinicos.Any())">
            + Nuevo Rango
        </button>
    </div>
</div>

<!-- Info clínica -->
<div class="dm-info-banner">
    <span class="dm-info-icon">ℹ️</span>
    <div>
        <strong>Motor de decisión clínica.</strong>
        El sistema evalúa cada rango en orden ascendente y aplica el primero que coincida con el valor del parámetro.
        Los rangos globales (sin tenant) son los predeterminados; los rangos del tenant los sobrescriben.
    </div>
</div>

@if (Cargando)
{
    <div class="dm-loading-container">
        <div class="dm-spinner"></div>
        <p>Cargando rangos...</p>
    </div>
}
else if (!RangosPorParametro.Any())
{
    <div class="dm-empty-state">
        <div class="dm-empty-icon">⚙️</div>
        <h3 class="dm-empty-title">Sin rangos configurados</h3>
        <p class="dm-empty-desc">Los rangos predeterminados se cargan con el script SQL de seed data.</p>
    </div>
}
else
{
    @foreach (var grupo in RangosPorParametro)
    {
        <div class="dm-param-section">
            <div class="dm-param-header">
                <div class="dm-param-info">
                    <span class="dm-param-codigo @ColorCodigo(grupo.Key)">@grupo.Key</span>
                    <span class="dm-param-nombre">@(ParametrosClinicos.FirstOrDefault(p => p.Codigo == grupo.Key)?.Nombre ?? grupo.Key)</span>
                    <span class="dm-param-count">@grupo.Value.Count rango(s)</span>
                </div>
                <button class="dm-btn dm-btn-sm dm-btn-outline"
                        @onclick="() => AbrirNuevoRangoParaParametro(grupo.Key)">
                    + Agregar rango
                </button>
            </div>

            <div class="dm-table-responsive dm-card">
                <table class="dm-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Nombre / Descripción</th>
                            <th class="dm-th-center">Valor Mínimo</th>
                            <th class="dm-th-center">Valor Máximo</th>
                            <th>Acción</th>
                            <th>Medicamento</th>
                            <th>Dosis Sugerida</th>
                            <th class="dm-th-center">Ajuste %</th>
                            <th>Alcance</th>
                            <th>Estado</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var rango in grupo.Value.OrderBy(r => r.Orden))
                        {
                            <tr class="@(!rango.Activo ? "dm-row-inactivo" : "")">
                                <td class="dm-td-orden">@rango.Orden</td>
                                <td>
                                    <div class="dm-rango-nombre">@rango.Nombre</div>
                                    @if (!string.IsNullOrEmpty(rango.Descripcion))
                                    {
                                        <div class="dm-rango-desc">@rango.Descripcion</div>
                                    }
                                </td>
                                <td class="dm-td-center">
                                    @if (rango.ValorMinimo.HasValue)
                                    {
                                        <span class="dm-valor-badge">≥ @rango.ValorMinimo.Value.ToString("G6")</span>
                                    }
                                    else { <span class="dm-sin-limite">Sin mín.</span> }
                                </td>
                                <td class="dm-td-center">
                                    @if (rango.ValorMaximo.HasValue)
                                    {
                                        <span class="dm-valor-badge">&lt; @rango.ValorMaximo.Value.ToString("G6")</span>
                                    }
                                    else { <span class="dm-sin-limite">Sin máx.</span> }
                                </td>
                                <td>
                                    <span class="dm-accion-badge @AccionClase(rango.Accion)">@rango.Accion</span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(rango.Medicamento))
                                    {
                                        <span class="dm-med-badge">@rango.Medicamento</span>
                                    }
                                    else { <span class="dm-sin-dato">—</span> }
                                </td>
                                <td class="dm-td-dosis">
                                    @if (!string.IsNullOrEmpty(rango.DosisSugerida))
                                    {
                                        <span title="@rango.DosisSugerida">
                                            @Truncate(rango.DosisSugerida, 40)
                                        </span>
                                    }
                                    else { <span class="dm-sin-dato">—</span> }
                                </td>
                                <td class="dm-td-center">
                                    @if (rango.AjustePorcentaje.HasValue)
                                    {
                                        <span class="@(rango.AjustePorcentaje > 0 ? "dm-pct-pos" : rango.AjustePorcentaje < 0 ? "dm-pct-neg" : "dm-pct-cero")">
                                            @(rango.AjustePorcentaje > 0 ? "+" : "")@rango.AjustePorcentaje.Value.ToString("F0")%
                                        </span>
                                    }
                                    else { <span class="dm-sin-dato">—</span> }
                                </td>
                                <td>
                                    @if (rango.TenantId.HasValue)
                                    {
                                        <span class="dm-scope-badge dm-scope-tenant">Este tenant</span>
                                    }
                                    else
                                    {
                                        <span class="dm-scope-badge dm-scope-global">Global</span>
                                    }
                                </td>
                                <td>
                                    <span class="@(rango.Activo ? "dm-activo" : "dm-inactivo")">
                                        @(rango.Activo ? "Activo" : "Inactivo")
                                    </span>
                                </td>
                                <td>
                                    <div class="dm-acciones">
                                        <button class="dm-btn-icon" @onclick="() => EditarRango(rango)"
                                                title="Editar">✏️</button>
                                    </div>
                                </td>
                            </tr>
                            @if (!string.IsNullOrEmpty(rango.Observacion))
                            {
                                <tr class="dm-row-obs">
                                    <td colspan="11">
                                        <span class="dm-obs-inline">📝 @rango.Observacion</span>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

<!-- Modal: Crear / Editar rango -->
@if (MostrarModal)
{
    <div class="dm-modal-overlay" @onclick="CerrarModal">
        <div class="dm-modal" @onclick:stopPropagation>
            <div class="dm-modal-header">
                <h2>@(RangoEditando.Id == Guid.Empty ? "Nuevo Rango" : "Editar Rango")</h2>
                <button class="dm-modal-close" @onclick="CerrarModal">✕</button>
            </div>
            <div class="dm-modal-body">
                <div class="dm-form-grid">
                    <div class="dm-form-group dm-form-full">
                        <label>Parámetro clínico *</label>
                        <select @bind="RangoEditando.ParametroClinicoId" class="dm-select" disabled="@(RangoEditando.Id != Guid.Empty)">
                            <option value="">— Seleccione —</option>
                            @foreach (var p in ParametrosClinicos)
                            {
                                <option value="@p.Id">@p.Codigo — @p.Nombre</option>
                            }
                        </select>
                    </div>
                    <div class="dm-form-group dm-form-full">
                        <label>Nombre del rango *</label>
                        <input type="text" @bind="RangoEditando.Nombre" class="dm-input"
                               placeholder="Ej: HB < 9 g/dL → Aumentar EPO 25%" />
                    </div>
                    <div class="dm-form-group dm-form-full">
                        <label>Descripción</label>
                        <input type="text" @bind="RangoEditando.Descripcion" class="dm-input"
                               placeholder="Detalle clínico adicional" />
                    </div>

                    <div class="dm-form-group">
                        <label>Valor mínimo (≥)</label>
                        <input type="number" step="0.01" @bind="ValorMinimoStr" class="dm-input"
                               placeholder="Sin límite inferior" />
                    </div>
                    <div class="dm-form-group">
                        <label>Valor máximo (&lt;)</label>
                        <input type="number" step="0.01" @bind="ValorMaximoStr" class="dm-input"
                               placeholder="Sin límite superior" />
                    </div>

                    <div class="dm-form-group">
                        <label>Acción *</label>
                        <select @bind="RangoEditando.Accion" class="dm-select">
                            <option value="">— Seleccione —</option>
                            <option value="AUMENTAR">AUMENTAR</option>
                            <option value="MANTENER">MANTENER</option>
                            <option value="REDUCIR">REDUCIR</option>
                            <option value="SUSPENDER">SUSPENDER</option>
                        </select>
                    </div>
                    <div class="dm-form-group">
                        <label>Medicamento</label>
                        <select @bind="RangoEditando.Medicamento" class="dm-select">
                            <option value="">— Todos —</option>
                            <option value="EPO">EPO</option>
                            <option value="HIERRO_IV">HIERRO IV</option>
                            <option value="AMBOS">AMBOS</option>
                        </select>
                    </div>

                    <div class="dm-form-group dm-form-full">
                        <label>Dosis sugerida</label>
                        <input type="text" @bind="RangoEditando.DosisSugerida" class="dm-input"
                               placeholder="Ej: Mantener dosis actual. Revaluar en 4 semanas." />
                    </div>

                    <div class="dm-form-group">
                        <label>Ajuste porcentaje (%)</label>
                        <input type="number" step="1" @bind="AjusteStr" class="dm-input"
                               placeholder="Ej: +25 o -10" />
                    </div>
                    <div class="dm-form-group">
                        <label>Orden (prioridad)</label>
                        <input type="number" min="1" max="999" @bind="RangoEditando.Orden" class="dm-input" />
                    </div>

                    <div class="dm-form-group dm-form-full">
                        <label>Observación clínica</label>
                        <textarea @bind="RangoEditando.Observacion" class="dm-textarea" rows="2"
                                  placeholder="Nota clínica que se mostrará en la prescripción sugerida"></textarea>
                    </div>

                    @if (!string.IsNullOrEmpty(ErrorModal))
                    {
                        <div class="dm-form-full dm-alert-error">@ErrorModal</div>
                    }
                </div>
            </div>
            <div class="dm-modal-footer">
                <button class="dm-btn dm-btn-outline" @onclick="CerrarModal">Cancelar</button>
                <button class="dm-btn dm-btn-primary" @onclick="GuardarRangoAsync" disabled="@Guardando">
                    @(Guardando ? "Guardando..." : "Guardar rango")
                </button>
            </div>
        </div>
    </div>
}

