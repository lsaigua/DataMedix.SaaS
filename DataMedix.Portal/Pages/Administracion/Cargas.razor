@page "/cargas"
@attribute [Authorize(Roles = "SUPERADMIN,ADMIN,OPERADOR")]
@using Microsoft.AspNetCore.Authorization
@using DataMedix.Application.Interfaces
@using DataMedix.Domain.Entities
@using System.Security.Claims

@inject ILoteImportacionRepository LoteRepo
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>Lotes de Carga | DataMedix</PageTitle>

<div class="dm-page-header">
    <div>
        <h1 class="dm-page-title">Lotes de Importación</h1>
        <p class="dm-page-subtitle">Historial de archivos Excel procesados por el sistema</p>
    </div>
    <div class="dm-page-actions">
        <a href="/laboratorio/importar" class="dm-btn dm-btn-primary">📤 Nueva Carga</a>
    </div>
</div>

<!-- Stats summary -->
<div class="dm-stats-row">
    <div class="dm-stat-card">
        <div class="dm-stat-num dm-stat-num-blue">@Lotes.Count</div>
        <div class="dm-stat-label">Total lotes</div>
    </div>
    <div class="dm-stat-card">
        <div class="dm-stat-num dm-stat-num-green">@Lotes.Count(l => l.Estado == EstadoLote.Completado)</div>
        <div class="dm-stat-label">Completados</div>
    </div>
    <div class="dm-stat-card">
        <div class="dm-stat-num dm-stat-num-yellow">@Lotes.Count(l => l.Estado == EstadoLote.Procesando || l.Estado == EstadoLote.Pendiente)</div>
        <div class="dm-stat-label">En proceso</div>
    </div>
    <div class="dm-stat-card">
        <div class="dm-stat-num dm-stat-num-red">@Lotes.Count(l => l.Estado == EstadoLote.Error)</div>
        <div class="dm-stat-label">Con error</div>
    </div>
    <div class="dm-stat-card">
        <div class="dm-stat-num dm-stat-num-blue">@Lotes.Sum(l => l.FilasValidas)</div>
        <div class="dm-stat-label">Registros importados</div>
    </div>
</div>

<!-- Filtro de estado -->
<div class="dm-filters-bar">
    <div class="dm-filter-group">
        <label>Estado</label>
        <select @bind="FiltroEstado" class="dm-select">
            <option value="">Todos</option>
            <option value="COMPLETADO">Completado</option>
            <option value="PROCESANDO">Procesando</option>
            <option value="PENDIENTE">Pendiente</option>
            <option value="ERROR">Con error</option>
            <option value="CANCELADO">Cancelado</option>
        </select>
    </div>
</div>

@if (Cargando)
{
    <div class="dm-loading-container">
        <div class="dm-spinner"></div>
        <p>Cargando lotes...</p>
    </div>
}
else if (!LotesFiltrados.Any())
{
    <div class="dm-empty-state">
        <div class="dm-empty-icon">📦</div>
        <h3 class="dm-empty-title">Sin lotes de importación</h3>
        <p class="dm-empty-desc">Aún no se han procesado archivos en este tenant.</p>
        <a href="/laboratorio/importar" class="dm-btn dm-btn-primary">📤 Importar primer archivo</a>
    </div>
}
else
{
    <div class="dm-card">
        <div class="dm-table-responsive">
            <table class="dm-table">
                <thead>
                    <tr>
                        <th>Archivo</th>
                        <th>Período</th>
                        <th>Estado</th>
                        <th class="dm-th-center">Total filas</th>
                        <th class="dm-th-center">Válidas</th>
                        <th class="dm-th-center">Errores</th>
                        <th class="dm-th-center">Duplicadas</th>
                        <th>Procesado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lote in LotesFiltrados)
                    {
                        <tr>
                            <td>
                                <div class="dm-archivo-cell">
                                    <div class="dm-archivo-icon">📊</div>
                                    <div>
                                        <div class="dm-archivo-nombre">@TruncateNombre(lote.NombreArchivoOriginal, 40)</div>
                                        <div class="dm-archivo-id">@lote.Id.ToString()[..8]...</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="dm-periodo-badge">
                                    @(new DateTime(lote.PeriodoAnio, lote.PeriodoMes, 1).ToString("MMMM yyyy"))
                                </span>
                            </td>
                            <td>
                                <span class="dm-estado-badge @EstadoClase(lote.Estado)">
                                    @EstadoIcon(lote.Estado) @lote.Estado
                                </span>
                            </td>
                            <td class="dm-td-center dm-num-total">@lote.TotalFilas</td>
                            <td class="dm-td-center">
                                <span class="@(lote.FilasValidas > 0 ? "dm-num-ok" : "dm-num-zero")">
                                    @lote.FilasValidas
                                </span>
                            </td>
                            <td class="dm-td-center">
                                <span class="@(lote.FilasError > 0 ? "dm-num-error" : "dm-num-zero")">
                                    @lote.FilasError
                                </span>
                            </td>
                            <td class="dm-td-center">
                                <span class="@(lote.FilasDuplicadas > 0 ? "dm-num-warn" : "dm-num-zero")">
                                    @lote.FilasDuplicadas
                                </span>
                            </td>
                            <td>
                                <div class="dm-fecha-cell">
                                    @if (lote.FechaInicioProceso.HasValue)
                                    {
                                        <span class="dm-fecha">@lote.FechaInicioProceso.Value.ToString("dd/MM/yyyy")</span>
                                        <span class="dm-hora">@lote.FechaInicioProceso.Value.ToString("HH:mm")</span>
                                        @if (lote.FechaFinProceso.HasValue)
                                        {
                                            var dur = lote.FechaFinProceso.Value - lote.FechaInicioProceso.Value;
                                            <span class="dm-duracion">@FormatDuracion(dur)</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="dm-sin-dato">—</span>
                                    }
                                </div>
                            </td>
                            <td>
                                <div class="dm-acciones">
                                    @if (lote.FilasError > 0)
                                    {
                                        <button class="dm-btn-icon dm-btn-icon-err"
                                                @onclick="() => VerErrores(lote)"
                                                title="Ver errores">
                                            ⚠️ @lote.FilasError
                                        </button>
                                    }
                                    <a href="/historial-clinico" class="dm-btn-icon" title="Ver resultados del período">
                                        📈
                                    </a>
                                    <a href="/prescripciones" class="dm-btn-icon" title="Ver prescripciones del período">
                                        💊
                                    </a>
                                </div>
                            </td>
                        </tr>
                        @if (!string.IsNullOrEmpty(lote.MensajeError))
                        {
                            <tr class="dm-error-row">
                                <td colspan="9">
                                    <div class="dm-error-msg">
                                        <span class="dm-error-icon">❌</span>
                                        @lote.MensajeError
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="dm-table-footer">
            <span class="dm-footer-info">
                Mostrando @LotesFiltrados.Count() de @Lotes.Count lotes
            </span>
            @if (HayMas)
            {
                <button class="dm-btn dm-btn-outline dm-btn-sm" @onclick="CargarMasAsync">
                    Cargar más
                </button>
            }
        </div>
    </div>
}

<!-- Modal errores -->
@if (ModalErroresVisible && LoteConErrores != null)
{
    <div class="dm-modal-overlay" @onclick="CerrarModal">
        <div class="dm-modal dm-modal-lg" @onclick:stopPropagation>
            <div class="dm-modal-header">
                <div>
                    <h2>Errores de importación</h2>
                    <p class="dm-modal-subtitle">
                        @TruncateNombre(LoteConErrores.NombreArchivoOriginal, 50)
                        — @ErroresLote.Count error(es),
                        @ErroresLote.Count(e => e.EsIgnorado) ignorado(s)
                    </p>
                </div>
                <button class="dm-modal-close" @onclick="CerrarModal">✕</button>
            </div>

            <div class="dm-modal-body">
                @if (CargandoErrores)
                {
                    <div class="dm-loading-container" style="padding:2rem">
                        <div class="dm-spinner"></div>
                        <p>Cargando errores...</p>
                    </div>
                }
                else if (!ErroresLote.Any())
                {
                    <div class="dm-empty-state" style="padding:2rem">
                        <div class="dm-empty-icon">✅</div>
                        <p>No se encontraron errores para este lote.</p>
                    </div>
                }
                else
                {
                    <table class="dm-table dm-table-compact">
                        <thead>
                            <tr>
                                <th style="width:40px">#</th>
                                <th style="width:60px">Fila</th>
                                <th style="width:160px">Tipo</th>
                                <th style="width:120px">Campo</th>
                                <th style="width:130px">Valor recibido</th>
                                <th>Motivo</th>
                                <th style="width:90px">Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var (err, idx) in ErroresLote.Select((e, i) => (e, i + 1)))
                            {
                                <tr class="@(err.EsIgnorado ? "dm-row-ignorada" : "")">
                                    <td class="dm-num-zero">@idx</td>
                                    <td class="dm-td-center">@(err.NumeroFila?.ToString() ?? "—")</td>
                                    <td><span class="dm-tipo-error-badge @TipoErrorClase(err.TipoError)">@err.TipoError</span></td>
                                    <td><code>@(err.Campo ?? "—")</code></td>
                                    <td><code class="dm-val-raw" title="@err.ValorRecibido">@(err.ValorRecibido ?? "—")</code></td>
                                    <td class="dm-error-msg-cell">@err.Mensaje</td>
                                    <td>
                                        @if (err.EsIgnorado)
                                        {
                                            <span class="dm-ignorado-badge">✓ Ignorado</span>
                                        }
                                        else
                                        {
                                            <button class="dm-btn-sm-action dm-btn-ignore"
                                                    @onclick="() => IgnorarErrorAsync(err)"
                                                    disabled="@CargandoAccion"
                                                    title="Marcar esta fila como revisada e ignorar el error">
                                                Ignorar
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>

            <div class="dm-modal-footer">
                <div class="dm-modal-footer-info">
                    @{
                        var pendientes = ErroresLote.Count(e => !e.EsIgnorado);
                    }
                    @if (pendientes == 0 && ErroresLote.Any())
                    {
                        <span class="dm-footer-ok">✓ Todos los errores han sido revisados</span>
                    }
                    else if (pendientes > 0)
                    {
                        <span class="dm-footer-warn">@pendientes error(es) sin revisar</span>
                    }
                </div>
                <div class="dm-modal-footer-actions">
                    @if (LoteConErrores.Estado != EstadoLote.Cancelado)
                    {
                        <button class="dm-btn dm-btn-danger dm-btn-sm"
                                @onclick="AbortarLoteAsync"
                                disabled="@CargandoAccion"
                                title="Cancela el lote e invalida todos sus datos">
                            @(CargandoAccion ? "⏳ Procesando..." : "⊘ Abortar lote")
                        </button>
                    }
                    <button class="dm-btn dm-btn-outline dm-btn-sm" @onclick="CerrarModal">
                        Cerrar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
