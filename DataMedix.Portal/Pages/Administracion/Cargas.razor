    .dm-btn { padding: 0.5rem 1rem; border-radius: 8px; font-weight: 600; font-size: 0.875rem;
              text-decoration: none; display: inline-flex; align-items: center; gap: 0.4rem;
              cursor: pointer; border: none; transition: all 0.15s; }
    .dm-btn-sm { padding: 0.35rem 0.75rem; font-size: 0.8rem; border-radius: 6px; }
    .dm-btn-primary { background: #0ea5e9; color: white; }
    .dm-btn-primary:hover { background: #0284c7; color: white; }
    .dm-btn-outline { background: white; color: #374151; border: 1.5px solid #e2e8f0; }
    .dm-btn-outline:hover { background: #f8fafc; }

    .dm-loading-container { display: flex; flex-direction: column; align-items: center; padding: 3rem; color: #64748b; gap: 1rem; }
