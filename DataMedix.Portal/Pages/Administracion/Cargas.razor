    .dm-row-ignorada { opacity: 0.45; background: #f8fafc !important; }
    .dm-row-ignorada td { text-decoration: line-through; color: #94a3b8 !important; }

    .dm-ignorado-badge { font-size: 0.72rem; color: #059669; font-weight: 700; }

    .dm-btn-sm-action { font-size: 0.72rem; padding: 0.2rem 0.55rem; border-radius: 5px;
                        cursor: pointer; border: 1.5px solid; font-weight: 600;
                        transition: all 0.15s; white-space: nowrap; }
    .dm-btn-sm-action:disabled { opacity: 0.5; cursor: not-allowed; }
    .dm-btn-ignore { border-color: #d97706; color: #d97706; background: transparent; }
    .dm-btn-ignore:hover:not(:disabled) { background: #fef3c7; }

    .dm-btn-danger { background: #dc2626; color: white; border: none; }
    .dm-btn-danger:hover:not(:disabled) { background: #b91c1c; }
</style>

@code {
    private List<LoteImportacion> Lotes = new();
    private List<ImportacionError> ErroresLote = new();
    private LoteImportacion? LoteConErrores;
    private bool Cargando = true;
    private bool HayMas = false;
    private bool ModalErroresVisible = false;
    private bool CargandoErrores = false;
    private bool CargandoAccion = false;
    private int PaginaActual = 1;
    private const int TamanoPagina = 30;
    private string FiltroEstado = string.Empty;
    private Guid TenantId;

    private IEnumerable<LoteImportacion> LotesFiltrados =>
        string.IsNullOrEmpty(FiltroEstado)
            ? Lotes
            : Lotes.Where(l => l.Estado == FiltroEstado);

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var tenantStr = auth.User.FindFirst("tenant_id")?.Value;
        TenantId = Guid.TryParse(tenantStr, out var t) ? t : Guid.Empty;
        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        Cargando = true;
        StateHasChanged();
        try
        {
            PaginaActual = 1;
            var resultado = await LoteRepo.GetByTenantAsync(TenantId, PaginaActual, TamanoPagina);
            Lotes = resultado;
            HayMas = resultado.Count == TamanoPagina;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando lotes: {ex.Message}");
            Lotes = new();
        }
        finally
        {
            Cargando = false;
        }
    }

    private async Task CargarMasAsync()
    {
        PaginaActual++;
        var mas = await LoteRepo.GetByTenantAsync(TenantId, PaginaActual, TamanoPagina);
        Lotes.AddRange(mas);
        HayMas = mas.Count == TamanoPagina;
    }

    private async Task VerErrores(LoteImportacion lote)
    {
        LoteConErrores = lote;
        ModalErroresVisible = true;
        CargandoErrores = true;
        StateHasChanged();
        try
        {
            ErroresLote = await LoteRepo.GetErroresByLoteAsync(lote.Id);
        }
        finally
        {
            CargandoErrores = false;
            StateHasChanged();
        }
    }

    private void CerrarModal()
    {
        ModalErroresVisible = false;
        LoteConErrores = null;
        ErroresLote.Clear();
    }

    private async Task IgnorarErrorAsync(ImportacionError err)
    {
        CargandoAccion = true;
        try
        {
            await LoteRepo.IgnorarErrorAsync(err.Id);
            err.EsIgnorado = true; // actualizar UI sin recargar
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al ignorar fila: {ex.Message}");
        }
        finally
        {
            CargandoAccion = false;
        }
    }

    private async Task AbortarLoteAsync()
    {
        if (LoteConErrores == null) return;
        CargandoAccion = true;
        try
        {
            await LoteRepo.CancelarLoteAsync(LoteConErrores);
            // reflejar en la lista local sin recargar todo
            var enLista = Lotes.FirstOrDefault(l => l.Id == LoteConErrores.Id);
            if (enLista != null) enLista.Estado = EstadoLote.Cancelado;
            CerrarModal();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al abortar lote: {ex.Message}");
        }
        finally
        {
            CargandoAccion = false;
        }
    }

    private static string EstadoClase(string estado) => estado switch
    {
        "COMPLETADO" => "dm-estado-completado",
        "PROCESANDO" => "dm-estado-procesando",
        "PENDIENTE" => "dm-estado-pendiente",
        "ERROR" => "dm-estado-error",
        "CANCELADO" => "dm-estado-cancelado",
        _ => ""
    };

    private static string EstadoIcon(string estado) => estado switch
    {
        "COMPLETADO" => "✓",
        "PROCESANDO" => "⏳",
        "PENDIENTE" => "⏸",
        "ERROR" => "✗",
        "CANCELADO" => "⊘",
        _ => "○"
    };

    private static string TipoErrorClase(string? tipo) => tipo switch
    {
        "VALIDACION" => "dm-tipo-validacion",
        "DUPLICADO" => "dm-tipo-duplicado",
        "PARSE" => "dm-tipo-parse",
        "PARAMETRO_NO_ENCONTRADO" => "dm-tipo-parametro",
        _ => "dm-tipo-default"
    };

    private static string FormatDuracion(TimeSpan dur)
    {
        if (dur.TotalSeconds < 60) return $"{dur.TotalSeconds:F0}s";
        if (dur.TotalMinutes < 60) return $"{dur.TotalMinutes:F1}min";
        return $"{dur.TotalHours:F1}h";
    }

    private static string TruncateNombre(string nombre, int max) =>
        nombre.Length > max ? nombre[..max] + "…" : nombre;
}
