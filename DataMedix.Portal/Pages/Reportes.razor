@code {
    private ResumenClinicoDto? _resumen;
    private List<string> _planesSalud = new();
    private bool _cargando = true;
    private string? _errorMensaje;
    private int _filtroMes = DateTime.Now.Month;
    private int _filtroAnio = DateTime.Now.Year;
    private string _planSalud = "";
    private string _filtroSeveridad = "TODAS";
    private Guid _tenantId;

    private IEnumerable<PacienteAlertaDto> PacientesFiltrados =>
        _filtroSeveridad == "TODAS"
            ? (_resumen?.PacientesAlerta ?? [])
            : (_resumen?.PacientesAlerta.Where(p =>
                p.Alertas.Any(a => a.Severidad == _filtroSeveridad)) ?? []);

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var tenantStr = auth.User.FindFirst("tenant_id")?.Value;
        _tenantId = Guid.TryParse(tenantStr, out var t) ? t : Guid.Empty;
        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        _cargando = true;
        _errorMensaje = null;
        StateHasChanged();

        try
        {
            var periodDate = new DateTime(_filtroAnio, _filtroMes, 1, 0, 0, 0, DateTimeKind.Utc);

            _planesSalud = await ReporteService.GetPlanesSaludAsync(_tenantId, periodDate);
            _resumen = await ReporteService.GetResumenPeriodoAsync(
                _tenantId, periodDate,
                string.IsNullOrEmpty(_planSalud) ? null : _planSalud);
        }
        catch (Exception ex)
        {
            _errorMensaje = ex.Message;
        }
        finally
        {
            _cargando = false;
        }
    }

    private static string ZonaClase(string zona) => zona switch
    {
        "critica"  => "dm-zona-critica",
        "baja"     => "dm-zona-baja",
        "atencion" => "dm-zona-atencion",
        "objetivo" => "dm-zona-objetivo",
        "alto"     => "dm-zona-alto",
        _ => "dm-zona-objetivo"
    };

    private static string ZonaBarClase(string zona) => zona switch
    {
        "critica"  => "dm-bar-dist-critica",
        "baja"     => "dm-bar-dist-baja",
        "atencion" => "dm-bar-dist-atencion",
        "objetivo" => "dm-bar-dist-objetivo",
        "alto"     => "dm-bar-dist-alto",
        _ => "dm-bar-dist-objetivo"
    };

    private static string SeveridadDotClase(string sev) => sev switch
    {
        "CRITICA" => "dm-alerta-dot dm-dot-sev-critica",
        "ALTA"    => "dm-alerta-dot dm-dot-sev-alta",
        _         => "dm-alerta-dot dm-dot-sev-media"
    };

    private static string SeveridadNumClase(string sev) => sev switch
    {
        "CRITICA" => "dm-alerta-total dm-num-critica",
        "ALTA"    => "dm-alerta-total dm-num-alta",
        _         => "dm-alerta-total dm-num-media"
    };

    private static string HbValClase(decimal? hb) =>
        !hb.HasValue ? "" : hb < 10 ? "dm-hb-val dm-hb-bajo" : hb > 13 ? "dm-hb-val dm-hb-alto" : "dm-hb-val dm-hb-ok";

    private static string BadgeClase(string sev) => sev switch
    {
        "CRITICA" => "dm-badge dm-badge-critica",
        "ALTA"    => "dm-badge dm-badge-alta",
        _         => "dm-badge dm-badge-media"
    };

    private static string EstadoClase(string estado) => estado switch
    {
        "PENDIENTE"  => "dm-rx-estado dm-rx-pendiente",
        "APROBADO"   => "dm-rx-estado dm-rx-aprobado",
        "REVISADO"   => "dm-rx-estado dm-rx-revisado",
        "RECHAZADO"  => "dm-rx-estado dm-rx-rechazado",
        _ => "dm-rx-estado"
    };

    private static string SevIcon(string sev) => sev switch
    {
        "CRITICA" => "🔴",
        "ALTA"    => "🟠",
        "MEDIA"   => "🟡",
        _ => "📋"
    };

    private static string TruncateDesc(string s, int max) =>
        s.Length <= max ? s : s[..max] + "…";
}
