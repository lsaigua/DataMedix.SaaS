@page "/reportes"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using DataMedix.Application.Interfaces
@using DataMedix.Application.DTOs
@using System.Security.Claims

@inject IReporteService ReporteService
@inject ISnapshotMensualRepository SnapshotRepo
@inject AuthenticationStateProvider AuthState

<PageTitle>Reportes Clínicos | DataMedix</PageTitle>

<div class="dm-page-header">
    <div>
        <h1 class="dm-page-title">Reportes Clínicos</h1>
        <p class="dm-page-subtitle">Panorama del estado de salud del grupo de pacientes en hemodiálisis</p>
    </div>
    <div class="dm-page-actions">
        <button class="dm-btn dm-btn-primary" @onclick="CargarAsync" disabled="@_cargando">
            @if (_cargando) { <span class="dm-spinner-sm"></span> }
            🔄 Actualizar
        </button>
    </div>
</div>

<!-- Filtros -->
<div class="dm-filters-bar">
    <div class="dm-filter-group">
        <label>Mes</label>
        <select @bind="_filtroMes" class="dm-select">
            @for (int m = 1; m <= 12; m++)
            {
                <option value="@m">@(new DateTime(2000, m, 1).ToString("MMMM"))</option>
            }
        </select>
    </div>
    <div class="dm-filter-group">
        <label>Año</label>
        <select @bind="_filtroAnio" class="dm-select">
            @for (int a = DateTime.Now.Year; a >= DateTime.Now.Year - 2; a--)
            {
                <option value="@a">@a</option>
            }
        </select>
    </div>
    @if (_planesSalud.Any())
    {
        <div class="dm-filter-group">
            <label>Plan de salud</label>
            <select @bind="_planSalud" class="dm-select">
                <option value="">Todos los planes</option>
                @foreach (var plan in _planesSalud)
                {
                    <option value="@plan">@plan</option>
                }
            </select>
        </div>
    }
</div>

@if (_errorMensaje != null)
{
    <div class="dm-error-banner"><span>⚠</span> @_errorMensaje</div>
}

@if (_cargando)
{
    <div class="dm-loading-container">
        <div class="dm-spinner"></div>
        <p>Generando reporte clínico...</p>
    </div>
}
else if (_resumen == null || _resumen.TotalPrescripciones == 0)
{
    <div class="dm-empty-state">
        <div class="dm-empty-icon">📊</div>
        <h3 class="dm-empty-title">Sin datos para este período</h3>
        <p class="dm-empty-desc">Importe resultados de laboratorio para generar el reporte clínico.</p>
        <a href="/laboratorio/importar" class="dm-btn dm-btn-primary">📤 Importar Resultados</a>
    </div>
}
else
{
    var r = _resumen!;

    <!-- ═══ KPIs ═══════════════════════════════════════════════════════════ -->
    <div class="dm-section-title">Resumen del período — @r.Periodo.ToString("MMMM yyyy")</div>
    <div class="dm-kpi-grid">
        <div class="dm-kpi dm-kpi-blue">
            <div class="dm-kpi-icon">👥</div>
            <div>
                <div class="dm-kpi-num">@r.TotalPacientesEvaluados</div>
                <div class="dm-kpi-lbl">Pacientes evaluados</div>
            </div>
        </div>
        <div class="dm-kpi dm-kpi-purple">
            <div class="dm-kpi-icon">💉</div>
            <div>
                <div class="dm-kpi-num">@r.PacientesConEpo</div>
                <div class="dm-kpi-lbl">Reciben EPO</div>
                <div class="dm-kpi-sub">@(r.TotalPrescripciones > 0 ? $"{r.PacientesConEpo * 100 / r.TotalPrescripciones}% del grupo" : "—")</div>
            </div>
        </div>
        <div class="dm-kpi dm-kpi-yellow">
            <div class="dm-kpi-icon">🔬</div>
            <div>
                <div class="dm-kpi-num">@r.PacientesConHierro</div>
                <div class="dm-kpi-lbl">Reciben Hierro IV</div>
                <div class="dm-kpi-sub">@(r.TotalPrescripciones > 0 ? $"{r.PacientesConHierro * 100 / r.TotalPrescripciones}% del grupo" : "—")</div>
            </div>
        </div>
        <div class="dm-kpi @(r.AlertasCriticas > 0 ? "dm-kpi-red" : "dm-kpi-green")">
            <div class="dm-kpi-icon">@(r.AlertasCriticas > 0 ? "🚨" : "✅")</div>
            <div>
                <div class="dm-kpi-num">@r.AlertasCriticas</div>
                <div class="dm-kpi-lbl">Alertas críticas</div>
                @if (r.AlertasAltas > 0)
                {
                    <div class="dm-kpi-sub">+ @r.AlertasAltas alta prioridad</div>
                }
            </div>
        </div>
        <div class="dm-kpi @(r.PorcentajeAprobacion >= 80 ? "dm-kpi-green" : r.PorcentajeAprobacion >= 50 ? "dm-kpi-yellow" : "dm-kpi-red")">
            <div class="dm-kpi-icon">@(r.PorcentajeAprobacion >= 80 ? "✅" : "⏳")</div>
            <div>
                <div class="dm-kpi-num">@r.PorcentajeAprobacion%</div>
                <div class="dm-kpi-lbl">Prescripciones aprobadas</div>
                <div class="dm-kpi-sub">@r.PrescripcionesPendientes pendientes</div>
            </div>
        </div>
    </div>

    <!-- ═══ PANORAMA CLÍNICO ════════════════════════════════════════════════ -->
    <div class="dm-two-col">

        <!-- Zonas de hemoglobina -->
        <div class="dm-card">
            <div class="dm-card-header">
                <h2 class="dm-card-title">🩸 Estado de Hemoglobina del grupo</h2>
                <p class="dm-card-desc">¿Cómo está la hemoglobina de los pacientes?</p>
            </div>

            @{
                int totalSnap = r.HbCritico + r.HbBajo + r.HbObjetivo + r.HbAlto + r.HbSinDato;
                int totalConHb = r.HbCritico + r.HbBajo + r.HbObjetivo + r.HbAlto;
                decimal pctCrit = totalSnap > 0 ? (decimal)r.HbCritico / totalSnap * 100 : 0;
                decimal pctBajo = totalSnap > 0 ? (decimal)r.HbBajo / totalSnap * 100 : 0;
                decimal pctObj  = totalSnap > 0 ? (decimal)r.HbObjetivo / totalSnap * 100 : 0;
                decimal pctAlto = totalSnap > 0 ? (decimal)r.HbAlto / totalSnap * 100 : 0;
            }

            <div class="dm-zones">
                <div class="dm-zone">
                    <div class="dm-zone-dot dm-dot-critica"></div>
                    <div class="dm-zone-info">
                        <span class="dm-zone-lbl">Zona crítica — Hb &lt; 8 g/dL</span>
                        <span class="dm-zone-hint">Requiere acción urgente</span>
                    </div>
                    <div class="dm-zone-bar-wrap">
                        <div class="dm-zone-bar dm-bar-critica" style="width:@(Math.Max(pctCrit,1))%"></div>
                    </div>
                    <span class="dm-zone-count dm-count-critica">@r.HbCritico pac.</span>
                </div>
                <div class="dm-zone">
                    <div class="dm-zone-dot dm-dot-baja"></div>
                    <div class="dm-zone-info">
                        <span class="dm-zone-lbl">Zona baja — Hb 8–10 g/dL</span>
                        <span class="dm-zone-hint">Monitorear de cerca</span>
                    </div>
                    <div class="dm-zone-bar-wrap">
                        <div class="dm-zone-bar dm-bar-baja" style="width:@(Math.Max(pctBajo,1))%"></div>
                    </div>
                    <span class="dm-zone-count dm-count-baja">@r.HbBajo pac.</span>
                </div>
                <div class="dm-zone">
                    <div class="dm-zone-dot dm-dot-objetivo"></div>
                    <div class="dm-zone-info">
                        <span class="dm-zone-lbl">Zona objetivo — Hb 10–13 g/dL</span>
                        <span class="dm-zone-hint">Rango clínico recomendado ✓</span>
                    </div>
                    <div class="dm-zone-bar-wrap">
                        <div class="dm-zone-bar dm-bar-objetivo" style="width:@(Math.Max(pctObj,1))%"></div>
                    </div>
                    <span class="dm-zone-count dm-count-objetivo">@r.HbObjetivo pac.</span>
                </div>
                <div class="dm-zone">
                    <div class="dm-zone-dot dm-dot-alto"></div>
                    <div class="dm-zone-info">
                        <span class="dm-zone-lbl">Zona alta — Hb &gt; 13 g/dL</span>
                        <span class="dm-zone-hint">Puede reducirse EPO</span>
                    </div>
                    <div class="dm-zone-bar-wrap">
                        <div class="dm-zone-bar dm-bar-alto" style="width:@(Math.Max(pctAlto,1))%"></div>
                    </div>
                    <span class="dm-zone-count dm-count-alto">@r.HbAlto pac.</span>
                </div>
                @if (r.HbSinDato > 0)
                {
                    <div class="dm-zone">
                        <div class="dm-zone-dot dm-dot-neutro"></div>
                        <div class="dm-zone-info">
                            <span class="dm-zone-lbl">Sin dato de Hb</span>
                            <span class="dm-zone-hint">Pendiente de resultado</span>
                        </div>
                        <div class="dm-zone-bar-wrap">
                            <div class="dm-zone-bar dm-bar-neutro" style="width:@(Math.Max((decimal)r.HbSinDato/totalSnap*100,1))%"></div>
                        </div>
                        <span class="dm-zone-count">@r.HbSinDato pac.</span>
                    </div>
                }
            </div>
        </div>

        <!-- Estado de prescripciones -->
        <div class="dm-card">
            <div class="dm-card-header">
                <h2 class="dm-card-title">📋 Estado de prescripciones</h2>
                <p class="dm-card-desc">¿Cuántas han sido revisadas y aprobadas?</p>
            </div>
            @{
                var estados = new[]
                {
                    ("Aprobadas", r.PrescripcionesAprobadas, "dm-estado-aprobado", "✅"),
                    ("Revisadas", r.TotalPrescripciones - r.PrescripcionesAprobadas
                        - r.PrescripcionesPendientes
                        - _resumen!.TotalPrescripciones + _resumen!.PrescripcionesAprobadas + r.PrescripcionesPendientes
                        + (_resumen.TotalPrescripciones - _resumen.PrescripcionesAprobadas - _resumen.PrescripcionesPendientes - 0), "dm-estado-revisado", "👁"),
                    ("Pendientes", r.PrescripcionesPendientes, "dm-estado-pendiente", "⏳"),
                };
                // Re-compute correctly
                int aprobadas   = r.PrescripcionesAprobadas;
                int pendientes  = r.PrescripcionesPendientes;
                int rechazadas  = r.TotalPrescripciones - aprobadas - pendientes - (r.TotalPrescripciones - aprobadas - pendientes); // placeholder
            }
            @* Simple approach: show each status as a progress bar *@
            <div class="dm-presc-estados">
                @{
                    var estadosData = new (string Label, int Count, string Clase, string Icon)[]
                    {
                        ("Aprobadas",  r.PrescripcionesAprobadas, "dm-est-green", "✅"),
                        ("Pendientes", r.PrescripcionesPendientes, "dm-est-orange", "⏳"),
                        ("Revisadas",  r.TotalPrescripciones - r.PrescripcionesAprobadas - r.PrescripcionesPendientes > 0
                            ? r.TotalPrescripciones - r.PrescripcionesAprobadas - r.PrescripcionesPendientes : 0,
                            "dm-est-blue", "👁"),
                    };
                }
                @foreach (var (label, count, clase, icon) in estadosData)
                {
                    if (count >= 0)
                    {
                        decimal pct = r.TotalPrescripciones > 0
                            ? Math.Round((decimal)count / r.TotalPrescripciones * 100, 1) : 0;
                        <div class="dm-est-row">
                            <span class="dm-est-label">@icon @label</span>
                            <div class="dm-est-track">
                                <div class="dm-est-fill @clase" style="width:@(Math.Max(pct,count>0?2:0))%"></div>
                            </div>
                            <span class="dm-est-nums">@count <span class="dm-est-pct">(@pct%)</span></span>
                        </div>
                    }
                }

                @if (r.ResumenAlertas.Any())
                {
                    <div class="dm-alertas-resumen">
                        <div class="dm-alertas-title">Alertas detectadas este período</div>
                        @foreach (var alerta in r.ResumenAlertas.Take(5))
                        {
                            <div class="dm-alerta-row">
                                <span class="dm-alerta-dot @SeveridadDotClase(alerta.Severidad)"></span>
                                <span class="dm-alerta-desc">@alerta.Descripcion</span>
                                <span class="dm-alerta-total @SeveridadNumClase(alerta.Severidad)">@alerta.Total</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- ═══ DISTRIBUCIÓN EPO ════════════════════════════════════════════════ -->
    @if (r.DistribucionEpo.Any())
    {
        <div class="dm-card">
            <div class="dm-card-header">
                <h2 class="dm-card-title">💉 ¿Qué dosis de EPO recibe cada paciente?</h2>
                <p class="dm-card-desc">
                    Distribución por nivel de hemoglobina — @r.PacientesConEpo de @r.TotalPrescripciones pacientes reciben EPO
                </p>
            </div>
            <div class="dm-dist-list">
                @{
                    int maxEpoPac = r.DistribucionEpo.Max(d => d.Pacientes);
                }
                @foreach (var d in r.DistribucionEpo)
                {
                    decimal barWidth = maxEpoPac > 0 ? (decimal)d.Pacientes / maxEpoPac * 100 : 0;
                    <div class="dm-dist-row">
                        <div class="dm-dist-label-col">
                            <span class="dm-dist-codigo @ZonaClase(d.Zona)">@d.Codigo</span>
                            <span class="dm-dist-desc">@TruncateDesc(d.Descripcion, 60)</span>
                        </div>
                        <div class="dm-dist-bar-col">
                            <div class="dm-dist-track">
                                <div class="dm-dist-fill @ZonaBarClase(d.Zona)"
                                     style="width:@(Math.Max(barWidth,2))%">
                                </div>
                            </div>
                        </div>
                        <div class="dm-dist-nums-col">
                            <span class="dm-dist-count">@d.Pacientes pac.</span>
                            @if (d.DosisPromedio.HasValue)
                            {
                                <span class="dm-dist-dosis">@d.DosisPromedio.Value.ToString("N0") UI/sem</span>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- ═══ DISTRIBUCIÓN HIERRO ══════════════════════════════════════════════ -->
    @if (r.DistribucionHierro.Any())
    {
        <div class="dm-card">
            <div class="dm-card-header">
                <h2 class="dm-card-title">🔬 ¿Qué dosis de Hierro IV recibe cada paciente?</h2>
                <p class="dm-card-desc">
                    Distribución por perfil de hierro — @r.PacientesConHierro de @r.TotalPrescripciones pacientes reciben Hierro IV
                </p>
            </div>
            <div class="dm-dist-list">
                @{
                    int maxHierroPac = r.DistribucionHierro.Max(d => d.Pacientes);
                }
                @foreach (var d in r.DistribucionHierro)
                {
                    decimal barWidth = maxHierroPac > 0 ? (decimal)d.Pacientes / maxHierroPac * 100 : 0;
                    <div class="dm-dist-row">
                        <div class="dm-dist-label-col">
                            <span class="dm-dist-codigo dm-zona-objetivo">@d.Codigo</span>
                            <span class="dm-dist-desc">@TruncateDesc(d.Descripcion, 60)</span>
                        </div>
                        <div class="dm-dist-bar-col">
                            <div class="dm-dist-track">
                                <div class="dm-dist-fill dm-bar-dist-objetivo"
                                     style="width:@(Math.Max(barWidth,2))%">
                                </div>
                            </div>
                        </div>
                        <div class="dm-dist-nums-col">
                            <span class="dm-dist-count">@d.Pacientes pac.</span>
                            @if (d.DosisPromedio.HasValue)
                            {
                                <span class="dm-dist-dosis">@d.DosisPromedio.Value.ToString("N0") mg/mes</span>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <!-- ═══ PACIENTES QUE REQUIEREN ATENCIÓN ════════════════════════════════ -->
    @if (r.PacientesAlerta.Any())
    {
        <div class="dm-card">
            <div class="dm-card-header-row">
                <div>
                    <h2 class="dm-card-title">🚨 Pacientes que requieren atención</h2>
                    <p class="dm-card-desc">Ordenados por prioridad — @r.PacientesAlerta.Count paciente(s) con alertas activas</p>
                </div>
                <div class="dm-alert-filters">
                    @foreach (var sev in new[] { "TODAS", "CRITICA", "ALTA", "MEDIA" })
                    {
                        <button class="dm-filter-chip @(_filtroSeveridad == sev ? "dm-chip-active" : "")"
                                @onclick="() => _filtroSeveridad = sev">
                            @SevIcon(sev) @sev.ToLower()
                        </button>
                    }
                </div>
            </div>

            <div class="dm-alert-table-wrap">
                <table class="dm-alert-table">
                    <thead>
                        <tr>
                            <th>Paciente</th>
                            <th style="text-align:center">Hb</th>
                            <th>Alertas</th>
                            <th style="text-align:center">Estado Rx</th>
                            <th style="text-align:center">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in PacientesFiltrados)
                        {
                            <tr class="@(p.SeveridadMaxima == "CRITICA" ? "dm-row-critica" : p.SeveridadMaxima == "ALTA" ? "dm-row-alta" : "")">
                                <td>
                                    <div class="dm-pac-cell">
                                        <div class="dm-avatar-sm @(p.SeveridadMaxima == "CRITICA" ? "dm-avatar-critica" : "")">
                                            @(p.NombreCompleto.FirstOrDefault())
                                        </div>
                                        <div>
                                            <div class="dm-pac-nombre">@p.NombreCompleto</div>
                                            <div class="dm-pac-id">@p.Identificacion</div>
                                        </div>
                                    </div>
                                </td>
                                <td style="text-align:center">
                                    @if (p.Hb.HasValue)
                                    {
                                        <span class="dm-hb-val @HbValClase(p.Hb)">@p.Hb.Value.ToString("F1")</span>
                                        <span class="dm-hb-unit">g/dL</span>
                                    }
                                    else { <span class="dm-sin-dato">—</span> }
                                </td>
                                <td>
                                    <div class="dm-badges-wrap">
                                        @foreach (var alerta in p.Alertas)
                                        {
                                            <span class="dm-badge @BadgeClase(alerta.Severidad)"
                                                  title="@alerta.Mensaje">
                                                @alerta.Descripcion
                                            </span>
                                        }
                                    </div>
                                </td>
                                <td style="text-align:center">
                                    <span class="dm-rx-estado @EstadoClase(p.EstadoPrescripcion)">
                                        @p.EstadoPrescripcion
                                    </span>
                                </td>
                                <td style="text-align:center">
                                    <a href="/prescripciones/@p.PacienteId"
                                       class="dm-btn dm-btn-xs @(p.SeveridadMaxima == "CRITICA" ? "dm-btn-danger" : "dm-btn-outline")">
                                        Ver Rx
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="dm-card dm-card-ok">
            <span class="dm-ok-icon">✅</span>
            <div>
                <strong>Sin alertas activas este período</strong>
                <p>Todos los pacientes están dentro de los rangos clínicos esperados.</p>
            </div>
        </div>
    }

    <!-- ═══ TENDENCIA HB ════════════════════════════════════════════════════ -->
    @if (r.TendenciaHb.Count > 1)
    {
        <div class="dm-card">
            <div class="dm-card-header">
                <h2 class="dm-card-title">📈 Tendencia de Hemoglobina del grupo</h2>
                <p class="dm-card-desc">Promedio de los últimos @r.TendenciaHb.Count meses — ¿está mejorando el grupo?</p>
            </div>

            @{
                decimal hbMin = r.TendenciaHb.Min(t => t.HbPromedio);
                decimal hbMax = r.TendenciaHb.Max(t => t.HbPromedio);
                decimal hbRange = Math.Max(hbMax - hbMin, 1m);
                decimal hbFirst = r.TendenciaHb.First().HbPromedio;
                decimal hbLast  = r.TendenciaHb.Last().HbPromedio;
                bool tendenciaPositiva = hbLast >= hbFirst;
            }

            <div class="dm-tendencia-header">
                <div class="dm-tendencia-stat">
                    <span class="dm-tend-val">@hbLast g/dL</span>
                    <span class="dm-tend-lbl">promedio actual</span>
                </div>
                <div class="dm-tendencia-arrow @(tendenciaPositiva ? "dm-arrow-up" : "dm-arrow-down")">
                    @(tendenciaPositiva ? "↑" : "↓")
                    <span>@(tendenciaPositiva ? "mejorando" : "disminuyendo")</span>
                </div>
                <div class="dm-tendencia-stat">
                    <span class="dm-tend-val">@(hbLast - hbFirst > 0 ? "+" : "")@((hbLast - hbFirst).ToString("F1")) g/dL</span>
                    <span class="dm-tend-lbl">vs. hace @r.TendenciaHb.Count meses</span>
                </div>
            </div>

            <div class="dm-trend-chart">
                @foreach (var t in r.TendenciaHb)
                {
                    decimal heightPct = hbRange > 0
                        ? Math.Min(Math.Max((t.HbPromedio - hbMin) / hbRange * 70 + 15, 10), 100)
                        : 50;
                    string barClase = t.HbPromedio < 10 ? "dm-trend-bar-baja"
                        : t.HbPromedio > 13 ? "dm-trend-bar-alto"
                        : "dm-trend-bar-ok";

                    <div class="dm-trend-col">
                        <div class="dm-trend-val">@t.HbPromedio</div>
                        <div class="dm-trend-bar-wrap">
                            <div class="dm-trend-bar @barClase"
                                 style="height:@((int)heightPct)%"></div>
                        </div>
                        <div class="dm-trend-label">@t.PeriodoLabel</div>
                        <div class="dm-trend-n">@t.Pacientes pac.</div>
                    </div>
                }
            </div>

            <div class="dm-hb-leyenda">
                <span><span class="dm-dot dm-dot-objetivo"></span>Zona objetivo (10-13 g/dL)</span>
                <span><span class="dm-dot dm-dot-baja"></span>Bajo (&lt;10 g/dL)</span>
                <span><span class="dm-dot dm-dot-alto"></span>Alto (&gt;13 g/dL)</span>
            </div>
        </div>
    }
}

<style>
    .dm-page-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem; }
    .dm-page-title { font-size: 1.75rem; font-weight: 700; color: #1e293b; margin: 0; }
    .dm-page-subtitle { color: #64748b; margin: 0.25rem 0 0; font-size: 0.9rem; }
    .dm-page-actions { display: flex; gap: 0.75rem; }

    .dm-filters-bar { display: flex; gap: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap; align-items: flex-end; }
    .dm-filter-group { display: flex; flex-direction: column; gap: 0.25rem; }
