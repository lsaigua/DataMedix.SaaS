@page "/prescripciones"
@page "/prescripciones/{PacienteId:guid}"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using DataMedix.Application.Interfaces
@using DataMedix.Domain.Entities
@using System.Security.Claims

@inject IPrescripcionRepository PrescripcionRepo
@inject ISnapshotMensualRepository SnapshotRepo
@inject IPacienteRepository PacienteRepo
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>Prescripciones | DataMedix</PageTitle>

<div class="dm-page-header">
    <div>
        <h1 class="dm-page-title">Prescripciones Clínicas</h1>
        @if (PacienteSeleccionado != null)
        {
            <p class="dm-page-subtitle">
                <a href="/pacientes" class="dm-link-back">← Pacientes</a>
                &nbsp;/&nbsp;@PacienteSeleccionado.NombreCompleto
                <span class="dm-ident-badge">@PacienteSeleccionado.Identificacion</span>
            </p>
        }
        else
        {
            <p class="dm-page-subtitle">EPO y Hierro IV sugeridos por el motor clínico</p>
        }
    </div>
    <div class="dm-page-actions">
        <button class="dm-btn dm-btn-outline" @onclick="CargarAsync" disabled="@Cargando">
            🔄 Actualizar
        </button>
    </div>
</div>

<!-- Filtros -->
<div class="dm-filters-bar">
    @if (!PacienteId.HasValue)
    {
        <div class="dm-search-box">
            <span>🔍</span>
            <input type="text" placeholder="Buscar paciente..." class="dm-search-input"
                   @bind="BusquedaTexto" @bind:event="oninput" @onkeyup="BuscarDebounced" />
        </div>
    }

    <div class="dm-filter-group">
        <label>Mes</label>
        <select @bind="FiltroMes" @bind:after="CargarAsync" class="dm-select">
            @for (int m = 1; m <= 12; m++)
            {
                <option value="@m">@(new DateTime(2000, m, 1).ToString("MMMM"))</option>
            }
        </select>
    </div>

    <div class="dm-filter-group">
        <label>Año</label>
        <select @bind="FiltroAnio" @bind:after="CargarAsync" class="dm-select">
            @for (int a = DateTime.Now.Year; a >= DateTime.Now.Year - 2; a--)
            {
                <option value="@a">@a</option>
            }
        </select>
    </div>

    <div class="dm-filter-group">
        <label>Estado</label>
        <select @bind="FiltroEstado" @bind:after="CargarAsync" class="dm-select">
            <option value="">Todos</option>
            <option value="PENDIENTE">Pendiente</option>
            <option value="REVISADO">Revisado</option>
            <option value="APROBADO">Aprobado</option>
            <option value="RECHAZADO">Rechazado</option>
        </select>
    </div>
</div>

<!-- Stats row -->
<div class="dm-stats-row">
    <div class="dm-stat-chip dm-stat-pending">
        <span class="dm-stat-num">@ListaPrescripciones.Count(p => p.Estado == "PENDIENTE")</span>
        <span class="dm-stat-lbl">Pendientes</span>
    </div>
    <div class="dm-stat-chip dm-stat-ok">
        <span class="dm-stat-num">@ListaPrescripciones.Count(p => p.Estado == "APROBADO")</span>
        <span class="dm-stat-lbl">Aprobadas</span>
    </div>
    <div class="dm-stat-chip dm-stat-info">
        <span class="dm-stat-num">@ListaPrescripciones.Count(p => p.Estado == "REVISADO")</span>
        <span class="dm-stat-lbl">Revisadas</span>
    </div>
    <div class="dm-stat-chip dm-stat-error">
        <span class="dm-stat-num">@ListaPrescripciones.Count(p => p.Estado == "RECHAZADO")</span>
        <span class="dm-stat-lbl">Rechazadas</span>
    </div>
</div>

@if (ErrorMensaje != null)
{
    <div class="dm-error-banner">
        <span>⚠</span> Error al cargar prescripciones: @ErrorMensaje
    </div>
}

@if (Cargando)
{
    <div class="dm-loading-container">
        <div class="dm-spinner"></div>
        <p>Cargando prescripciones...</p>
    </div>
}
else if (!PrescripcionesFiltradas.Any())
{
    <div class="dm-empty-state">
        <div class="dm-empty-icon">💊</div>
        <h3 class="dm-empty-title">Sin prescripciones para el período</h3>
        <p class="dm-empty-desc">Importe resultados de laboratorio para generar prescripciones automáticas.</p>
        <a href="/laboratorio/importar" class="dm-btn dm-btn-primary">📤 Importar Resultados</a>
    </div>
}
else
{
    <div class="dm-cards-grid">
        @foreach (var presc in PrescripcionesFiltradas)
        {
            var snap = Snapshots.FirstOrDefault(s => s.PacienteId == presc.PacienteId && s.PeriodDate == presc.PeriodDate);
            <div class="dm-presc-card @(presc.Estado == "PENDIENTE" ? "dm-card-pending" : "")">
                <div class="dm-presc-card-header">
                    <div class="dm-paciente-cell">
                        <div class="dm-avatar">@(presc.Paciente?.PrimerNombre?.FirstOrDefault() ?? '?')</div>
                        <div>
                            <div class="dm-nombre">@(presc.Paciente?.NombreCompleto ?? "Paciente")</div>
                            <div class="dm-ident-small">@(presc.Paciente?.Identificacion ?? "—")</div>
                        </div>
                    </div>
                    <div class="dm-presc-meta">
                        <span class="dm-periodo-badge">@presc.PeriodDate.ToString("MMM yyyy")</span>
                        <span class="dm-estado-badge @EstadoClase(presc.Estado)">@presc.Estado</span>
                    </div>
                </div>

                <!-- Datos del snapshot -->
                @if (snap != null)
                {
                    <div class="dm-snap-row">
                        <div class="dm-snap-param">
                            <span class="dm-snap-label">HB</span>
                            <span class="@ValorClaseHb(snap.HbValor)">
                                @(snap.HbValor.HasValue ? $"{snap.HbValor:F1} g/dL" : "—")
                            </span>
                        </div>
                        <div class="dm-snap-param">
                            <span class="dm-snap-label">Ferritina</span>
                            <span class="@ValorClaseFerr(snap.FerritinaValor)">
                                @(snap.FerritinaValor.HasValue ? $"{snap.FerritinaValor:F0} ng/mL" : "—")
                            </span>
                        </div>
                        <div class="dm-snap-param">
                            <span class="dm-snap-label">ISAT</span>
                            <span class="@ValorClaseIsat(snap.SaturacionValor)">
                                @(snap.SaturacionValor.HasValue ? $"{snap.SaturacionValor:F1}%" : "—")
                            </span>
                        </div>
                        <div class="dm-snap-param">
                            <span class="dm-snap-label">Hierro</span>
                            <span class="dm-valor-neutro">
                                @(snap.HierroValor.HasValue ? $"{snap.HierroValor:F0} ug/dL" : "—")
                            </span>
                        </div>
                    </div>
                }

                <!-- Sugerencias del motor -->
                <div class="dm-suggestions">
                    <!-- EPO -->
                    <div class="dm-sug-block dm-sug-epo">
                        <div class="dm-sug-header">
                            <span class="dm-sug-icon">💉</span>
                            <span class="dm-sug-title">EPO</span>
                            @if (!string.IsNullOrEmpty(presc.EpoAccion))
                            {
                                <span class="dm-accion-badge @AccionClase(presc.EpoAccion)">@presc.EpoAccion</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(presc.EpoDosisSugerida))
                        {
                            <div class="dm-sug-dosis">📋 @presc.EpoDosisSugerida</div>
                        }
                        @if (!string.IsNullOrEmpty(presc.EpoObservacion))
                        {
                            <div class="dm-sug-obs">@presc.EpoObservacion</div>
                        }
                        @if (string.IsNullOrEmpty(presc.EpoAccion) && string.IsNullOrEmpty(presc.EpoObservacion))
                        {
                            <div class="dm-sin-dato">Sin datos suficientes</div>
                        }
                    </div>

                    <!-- Hierro IV -->
                    <div class="dm-sug-block dm-sug-hierro">
                        <div class="dm-sug-header">
                            <span class="dm-sug-icon">🔬</span>
                            <span class="dm-sug-title">Hierro IV</span>
                            @if (!string.IsNullOrEmpty(presc.HierroAccion))
                            {
                                <span class="dm-accion-badge @AccionClase(presc.HierroAccion)">@presc.HierroAccion</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(presc.HierroDosisSugerida))
                        {
                            <div class="dm-sug-dosis">📋 @presc.HierroDosisSugerida</div>
                        }
                        @if (!string.IsNullOrEmpty(presc.HierroObservacion))
                        {
                            <div class="dm-sug-obs">@presc.HierroObservacion</div>
                        }
                        @if (string.IsNullOrEmpty(presc.HierroAccion) && string.IsNullOrEmpty(presc.HierroObservacion))
                        {
                            <div class="dm-sin-dato">Sin datos suficientes</div>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(presc.ObservacionesGenerales))
                {
                    <div class="dm-obs-generales">
                        <span class="dm-obs-icon">📝</span> @presc.ObservacionesGenerales
                    </div>
                }

                <!-- Acciones de revisión -->
                @if (presc.Estado == EstadoPrescripcion.Pendiente)
                {
                    <div class="dm-presc-actions">
                        <button class="dm-btn dm-btn-sm dm-btn-success"
                                @onclick="() => AprobarAsync(presc)">
                            ✓ Aprobar
                        </button>
                        <button class="dm-btn dm-btn-sm dm-btn-warning"
                                @onclick="() => MarcarRevisadoAsync(presc)">
                            👁 Marcar revisado
                        </button>
                        <button class="dm-btn dm-btn-sm dm-btn-danger-outline"
                                @onclick="() => RechazarAsync(presc)">
                            ✗ Rechazar
                        </button>
                        <a href="/historial-clinico/@presc.PacienteId" class="dm-btn dm-btn-sm dm-btn-outline">
                            📈 Historial
                        </a>
                    </div>
                }
                else
                {
                    <div class="dm-presc-actions">
                        <a href="/historial-clinico/@presc.PacienteId" class="dm-btn dm-btn-sm dm-btn-outline">
                            📈 Ver historial
                        </a>
                        @if (presc.RevisadoAt.HasValue)
                        {
                            <span class="dm-revisado-info">
                                Revisado @presc.RevisadoAt.Value.ToString("dd/MM/yyyy HH:mm")
                            </span>
                        }
                    </div>
                }
            </div>
        }
    </div>
}

