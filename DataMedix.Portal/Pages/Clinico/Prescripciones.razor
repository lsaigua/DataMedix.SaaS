@code {
    [Parameter] public Guid? PacienteId { get; set; }

    private List<PrescripcionSugerida> ListaPrescripciones = new();
    private List<SnapshotMensual> Snapshots = new();
    private Paciente? PacienteSeleccionado;
    private bool Cargando = true;
    private string BusquedaTexto = string.Empty;
    private int FiltroMes = DateTime.Now.Month;
    private int FiltroAnio = DateTime.Now.Year;
    private string FiltroEstado = string.Empty;
    private Guid TenantId;
    private string? ErrorMensaje;
    private System.Threading.CancellationTokenSource? _debounce;

    // Contextos expandidos
    private readonly HashSet<Guid> _contextosExpandidos = new();

    // Modal de aprobación
    private PrescripcionSugerida? _aprobandoPresc;
    private bool _modalAprobar = false;
    private bool _epoPrescrito;
    private string _epoDosis = "";
    private string _epoFrecuencia = "Semanal";
    private bool _hierroPrescrito;
    private string _hierroDosis = "";
    private string _hierroFrecuencia = "Mensual";
    private string _diagnostico = "";
    private string _observacionesFinal = "";
    private bool _guardando = false;
    private string? _modalError;

    private static readonly JsonSerializerOptions _jsonOpts = new() { PropertyNameCaseInsensitive = true };
    private static readonly JsonSerializerOptions _jsonIndented = new() { WriteIndented = true };

    private IEnumerable<PrescripcionSugerida> PrescripcionesFiltradas =>
        ListaPrescripciones.Where(p =>
            (string.IsNullOrEmpty(FiltroEstado) || p.Estado == FiltroEstado) &&
            (string.IsNullOrEmpty(BusquedaTexto) ||
             (p.Paciente?.NombreCompleto?.Contains(BusquedaTexto, StringComparison.OrdinalIgnoreCase) ?? false) ||
             (p.Paciente?.Identificacion?.Contains(BusquedaTexto, StringComparison.OrdinalIgnoreCase) ?? false)));

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var tenantStr = auth.User.FindFirst("tenant_id")?.Value;
        TenantId = Guid.TryParse(tenantStr, out var t) ? t : Guid.Empty;

        if (PacienteId.HasValue)
            PacienteSeleccionado = await PacienteRepo.GetByIdAsync(TenantId, PacienteId.Value);

        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        Cargando = true;
        ErrorMensaje = null;
        StateHasChanged();

        try
        {
            var periodDate = new DateTime(FiltroAnio, FiltroMes, 1, 0, 0, 0, DateTimeKind.Utc);

            if (PacienteId.HasValue)
            {
                var presc = await PrescripcionRepo.GetSugeridaByPacienteYPeriodoAsync(TenantId, PacienteId.Value, periodDate);
                ListaPrescripciones = presc != null ? [presc] : [];

                var snap = await SnapshotRepo.GetByPacienteYPeriodoAsync(TenantId, PacienteId.Value, periodDate);
                Snapshots = snap != null ? [snap] : [];
            }
            else
            {
                ListaPrescripciones = await PrescripcionRepo.GetByPeriodoAsync(TenantId, periodDate);
                Snapshots = await SnapshotRepo.GetByPeriodoAsync(TenantId, periodDate);
            }
        }
        catch (Exception ex)
        {
            ListaPrescripciones = [];
            ErrorMensaje = ex.Message;
        }
        finally
        {
            Cargando = false;
        }
    }

    private void AbrirModalAprobar(PrescripcionSugerida presc)
    {
        _aprobandoPresc = presc;
        _epoPrescrito = presc.EpoUiSemana.HasValue && presc.EpoUiSemana > 0;
        _epoDosis = presc.EpoUiSemana.HasValue
            ? $"{presc.EpoUiSemana.Value:N0} UI/sem"
            : presc.EpoDosisSugerida ?? "";
        _epoFrecuencia = "Semanal";
        _hierroPrescrito = presc.HierroMgMes.HasValue && presc.HierroMgMes > 0;
        _hierroDosis = presc.HierroMgMes.HasValue
            ? $"{presc.HierroMgMes.Value:N0} mg/mes"
            : presc.HierroDosisSugerida ?? "";
        _hierroFrecuencia = "Mensual";
        _diagnostico = "";
        _observacionesFinal = "";
        _modalError = null;
        _modalAprobar = true;
    }

    private void CerrarModal()
    {
        if (_guardando) return;
        _modalAprobar = false;
        _aprobandoPresc = null;
    }

    private async Task ConfirmarAprobacionAsync()
    {
        if (_aprobandoPresc == null) return;

        _modalError = null;
        _guardando = true;
        StateHasChanged();

        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            var userId = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (!Guid.TryParse(userId, out var medicoId))
            {
                _modalError = "No se pudo identificar al médico. Recargue la sesión.";
                return;
            }

            var final = new PrescripcionFinal
            {
                TenantId      = _aprobandoPresc.TenantId,
                PacienteId    = _aprobandoPresc.PacienteId,
                PrescripcionSugeridaId = _aprobandoPresc.Id,
                MedicoId      = medicoId,
                PeriodDate    = _aprobandoPresc.PeriodDate,
                EpoPrescrito  = _epoPrescrito,
                EpoDosis      = _epoPrescrito ? _epoDosis.Trim() : null,
                EpoFrecuencia = _epoPrescrito ? _epoFrecuencia : null,
                HierroPrescrito  = _hierroPrescrito,
                HierroDosis      = _hierroPrescrito ? _hierroDosis.Trim() : null,
                HierroFrecuencia = _hierroPrescrito ? _hierroFrecuencia : null,
                Diagnostico      = string.IsNullOrWhiteSpace(_diagnostico) ? null : _diagnostico.Trim(),
                Observaciones    = string.IsNullOrWhiteSpace(_observacionesFinal) ? null : _observacionesFinal.Trim(),
            };

            _aprobandoPresc.Estado      = EstadoPrescripcion.Aprobado;
            _aprobandoPresc.RevisadoAt  = DateTime.UtcNow;
            _aprobandoPresc.RevisadoPor = medicoId;

            await PrescripcionRepo.AddFinalAsync(final);
            await PrescripcionRepo.UpsertSugeridaAsync(_aprobandoPresc);

            _modalAprobar = false;
            _aprobandoPresc = null;
        }
        catch (Exception ex)
        {
            _modalError = ex.Message;
        }
        finally
        {
            _guardando = false;
        }
    }

    private async Task MarcarRevisadoAsync(PrescripcionSugerida presc)
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        presc.Estado = EstadoPrescripcion.Revisado;
        presc.RevisadoAt = DateTime.UtcNow;
        if (Guid.TryParse(userId, out var uid)) presc.RevisadoPor = uid;
        await PrescripcionRepo.UpsertSugeridaAsync(presc);
        StateHasChanged();
    }

    private async Task RechazarAsync(PrescripcionSugerida presc)
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        presc.Estado = EstadoPrescripcion.Rechazado;
        presc.RevisadoAt = DateTime.UtcNow;
        if (Guid.TryParse(userId, out var uid)) presc.RevisadoPor = uid;
        await PrescripcionRepo.UpsertSugeridaAsync(presc);
        StateHasChanged();
    }

    private async Task BuscarDebounced()
    {
        _debounce?.Cancel();
        _debounce = new System.Threading.CancellationTokenSource();
        var token = _debounce.Token;
        await Task.Delay(400, token).ContinueWith(async t =>
        {
            if (t.IsCompletedSuccessfully)
                await InvokeAsync(StateHasChanged);
        });
    }

    private void ToggleContexto(Guid id)
    {
        if (!_contextosExpandidos.Remove(id))
            _contextosExpandidos.Add(id);
    }

    private static List<AlertaClinica> ParseAlertas(string? json)
    {
        if (string.IsNullOrEmpty(json)) return [];
        try { return JsonSerializer.Deserialize<List<AlertaClinica>>(json, _jsonOpts) ?? []; }
        catch { return []; }
    }

    private static string FormatJson(string? json)
    {
        if (string.IsNullOrEmpty(json)) return "";
        try
        {
            var doc = JsonDocument.Parse(json);
            return JsonSerializer.Serialize(doc, _jsonIndented);
        }
        catch { return json; }
    }

    private static string AlertaBadgeClase(string severidad) => severidad switch
    {
        "CRITICA" => "dm-alerta-critica",
        "ALTA"    => "dm-alerta-alta",
        _         => "dm-alerta-media"
    };

    private static string AlertaIcon(string severidad) => severidad switch
    {
        "CRITICA" => "🔴",
        "ALTA"    => "🟠",
        _         => "🟡"
    };

    private static int SeveridadOrden(string severidad) => severidad switch
    {
        "CRITICA" => 0,
        "ALTA"    => 1,
        _         => 2
    };

    private static string EstadoClase(string estado) => estado switch
    {
        "PENDIENTE" => "dm-estado-pendiente",
        "REVISADO"  => "dm-estado-revisado",
        "APROBADO"  => "dm-estado-aprobado",
        "RECHAZADO" => "dm-estado-rechazado",
        _ => ""
    };

    private static string AccionClase(string accion) => accion switch
    {
        "AUMENTAR"  => "dm-accion-aumentar",
        "MANTENER"  => "dm-accion-mantener",
        "REDUCIR"   => "dm-accion-reducir",
        "SUSPENDER" => "dm-accion-suspender",
        _ => ""
    };

    private static string ValorClaseHb(decimal? v) =>
        !v.HasValue ? "dm-valor-neutro" :
        v < 10 ? "dm-valor-hb-bajo" : v > 13 ? "dm-valor-hb-alto" : "dm-valor-hb-ok";

    private static string ValorClaseFerr(decimal? v) =>
        !v.HasValue ? "dm-valor-neutro" :
        v < 200 ? "dm-valor-ferr-bajo" : v > 500 ? "dm-valor-ferr-alto" : "dm-valor-ferr-ok";

    private static string ValorClaseIsat(decimal? v) =>
        !v.HasValue ? "dm-valor-neutro" :
        v < 20 ? "dm-valor-isat-bajo" : "dm-valor-isat-ok";
}
