</style>

@code {
    // ── Filtros ──────────────────────────────────────────────────────────────
    private string  BusquedaTexto    = string.Empty;
    private bool    BusquedaActiva   => !string.IsNullOrEmpty(BusquedaTexto) && BusquedaTexto.Length >= 3;
    private Guid?   FiltroParametroId;
    private int     FiltroMesDe      = DateTime.Now.Month;
    private int     FiltroAnioDe     = DateTime.Now.Year;
    private int     FiltroMesHasta   = DateTime.Now.Month;
    private int     FiltroAnioHasta  = DateTime.Now.Year;

    // ── Estado ───────────────────────────────────────────────────────────────
    private List<HojaEpoRowDto>    Filas       = new();
    private List<ParametroClinico> Parametros  = new();
    private HojaEpoFiltroDto       FiltroActual = new();
    private bool   Cargando      = false;
    private bool   HaBuscado     = false;
    private string? ErrorMensaje;
    private Guid   TenantId;
    private Guid   MedicoId;

    // ── Edición inline ───────────────────────────────────────────────────────
    private (Guid PacienteId, DateTime PeriodDate)? _editKey;
    private string? _tempAjusteEpo;
    private string? _tempAjusteHierro;
    private bool    _guardandoCelda;
    private string? _mensajeGuardado;
    private bool    _mensajeGuardadoOk;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var tenantStr = auth.User.FindFirst("tenant_id")?.Value;
        TenantId = Guid.TryParse(tenantStr, out var t) ? t : Guid.Empty;
        Guid.TryParse(auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out MedicoId);

        Parametros = await ParametroRepo.GetAllAsync(soloActivos: true);
    }

    private async Task BuscarAsync()
    {
        if (!string.IsNullOrEmpty(BusquedaTexto) && BusquedaTexto.Length < 3) return;

        Cargando     = true;
        HaBuscado    = true;
        ErrorMensaje = null;
        _editKey     = null;
        StateHasChanged();

        try
        {
            FiltroActual = new HojaEpoFiltroDto
            {
                BusquedaPaciente  = string.IsNullOrWhiteSpace(BusquedaTexto) ? null : BusquedaTexto.Trim(),
                ParametroClinicoId = FiltroParametroId == Guid.Empty ? null : FiltroParametroId,
                MesDe     = FiltroMesDe,
                AnioDe    = FiltroAnioDe,
                MesHasta  = FiltroMesHasta,
                AnioHasta = FiltroAnioHasta,
            };

            Filas = await HojaEpoSvc.GetMatrizAsync(TenantId, FiltroActual);
        }
        catch (Exception ex)
        {
            ErrorMensaje = ex.Message;
            Filas = [];
        }
        finally
        {
            Cargando = false;
        }
    }

    private void LimpiarFiltros()
    {
        BusquedaTexto    = string.Empty;
        FiltroParametroId = null;
        FiltroMesDe      = DateTime.Now.Month;
        FiltroAnioDe     = DateTime.Now.Year;
        FiltroMesHasta   = DateTime.Now.Month;
        FiltroAnioHasta  = DateTime.Now.Year;
        Filas            = [];
        HaBuscado        = false;
        ErrorMensaje     = null;
        _editKey         = null;
    }

    private void LimpiarBusqueda()
    {
        BusquedaTexto = string.Empty;
    }

    private async Task OnBusquedaKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && BusquedaActiva)
            await BuscarAsync();
    }

    // ── Edición inline ───────────────────────────────────────────────────────
    private void AbrirEdicion(HojaEpoRowDto row, DateTime mes, HojaEpoCeldaDto celda)
    {
        _editKey         = (row.PacienteId, mes);
        _tempAjusteEpo   = celda.AjusteEpo;
        _tempAjusteHierro = celda.AjusteHierro;
    }

    private void CancelarEdicion()
    {
        _editKey         = null;
        _tempAjusteEpo   = null;
        _tempAjusteHierro = null;
    }

    private async Task OnEditKeyDown(KeyboardEventArgs e, HojaEpoRowDto row, DateTime mes)
    {
        if (e.Key == "Enter")  await GuardarCeldaAsync(row, mes);
        if (e.Key == "Escape") CancelarEdicion();
    }

    private async Task GuardarCeldaAsync(HojaEpoRowDto row, DateTime mes)
    {
        if (_guardandoCelda) return;
        _guardandoCelda = true;
        _mensajeGuardado = null;
        StateHasChanged();

        try
        {
            var celda = row.Meses.TryGetValue(mes, out var c) ? c : null;

            await HojaEpoSvc.GuardarAjusteAsync(
                TenantId, row.PacienteId, mes,
                _tempAjusteEpo, _tempAjusteHierro,
                MedicoId, celda?.PrescripcionSugeridaId);

            // Actualizar la celda en memoria para reflejo inmediato
            if (celda == null)
            {
                celda = new HojaEpoCeldaDto { PeriodDate = mes };
                row.Meses[mes] = celda;
            }
            celda.AjusteEpo    = string.IsNullOrWhiteSpace(_tempAjusteEpo)    ? null : _tempAjusteEpo!.Trim();
            celda.AjusteHierro = string.IsNullOrWhiteSpace(_tempAjusteHierro) ? null : _tempAjusteHierro!.Trim();

            _editKey             = null;
            _mensajeGuardado     = $"Ajuste guardado — {row.NombrePaciente} {mes:MMM yyyy}";
            _mensajeGuardadoOk   = true;

            // Ocultar el toast automáticamente
            _ = OcultarToastAsync();
        }
        catch (Exception ex)
        {
            _mensajeGuardado   = $"Error al guardar: {ex.Message}";
            _mensajeGuardadoOk = false;
        }
        finally
        {
            _guardandoCelda = false;
        }
    }

    private async Task OcultarToastAsync()
    {
        await Task.Delay(3500);
        _mensajeGuardado = null;
        StateHasChanged();
    }

    // ── Helpers de formato ───────────────────────────────────────────────────
    private static string FmtDec(decimal? v, string fmt = "F0") =>
        v.HasValue ? v.Value.ToString(fmt) : "—";

    private static string NombreMes(int m) =>
        new DateTime(2000, m, 1).ToString("MMM");

    private static string HbClase(decimal? v) =>
        v == null ? "" :
        v < 10    ? "epo-hb-bajo-cell" :
        v > 13    ? "epo-hb-alto-cell" : "epo-hb-ok-cell";

    private static string FerrClase(decimal? v) =>
        v == null ? "" :
        v < 200   ? "epo-ferr-bajo-cell" :
        v > 500   ? "epo-ferr-alto-cell" : "";

    private static string IsatClase(decimal? v) =>
        v == null ? "" : v < 20 ? "epo-isat-bajo-cell" : "";

    private static string AccionClase(string? a) => a switch
    {
        "AUMENTAR"  => "epo-accion-aumentar",
        "MANTENER"  => "epo-accion-mantener",
        "REDUCIR"   => "epo-accion-reducir",
        "SUSPENDER" => "epo-accion-suspender",
        _ => ""
    };

    private static string EstadoClase(string e) => e switch
    {
        "PENDIENTE" => "epo-estado-pendiente",
        "REVISADO"  => "epo-estado-revisado",
        "APROBADO"  => "epo-estado-aprobado",
        "RECHAZADO" => "epo-estado-rechazado",
        _ => "epo-estado-sindatos"
    };

    private static string EstadoShort(string e) => e switch
    {
        "PENDIENTE" => "PEND",
        "REVISADO"  => "REV",
        "APROBADO"  => "APRO",
        "RECHAZADO" => "RECH",
        _ => "S/D"
    };
}
