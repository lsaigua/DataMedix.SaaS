                       border-radius: 10px; font-weight: 600; font-size: 0.875rem; z-index: 2000;
                       animation: slideIn 0.2s ease; box-shadow: 0 4px 16px rgba(0,0,0,0.15); }
    .epo-toast-ok  { background: #dcfce7; color: #166534; border: 1px solid #86efac; }
