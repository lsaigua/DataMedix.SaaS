    /* States */
    .epo-loading { display: flex; flex-direction: column; align-items: center; padding: 3rem; gap: 1rem; color: #64748b; }
    .epo-empty-state { text-align: center; padding: 3rem 2rem; color: #64748b;
                        background: white; border-radius: 12px; border: 1.5px solid #e2e8f0; }
    .epo-empty-intro { background: linear-gradient(135deg,#f0f9ff,#f5f3ff); border-color: #bae6fd; }
