@page "/clinico/reglas"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using DataMedix.Application.Interfaces
@using DataMedix.Application.RuleEngine
@using DataMedix.Domain.Entities
@using System.Security.Claims
@using System.Text.Json

@inject IReglaClinicaRepository ReglaRepo
@inject IRuleCache RuleCache
@inject AuthenticationStateProvider AuthState

<PageTitle>Reglas Clínicas | DataMedix</PageTitle>

<div class="dm-page-header">
    <div>
        <h1 class="dm-page-title">Reglas Clínicas</h1>
        <p class="dm-page-subtitle">Motor de reglas KDIGO configurable — @_todasLasReglas.Count reglas cargadas</p>
    </div>
    <div class="dm-page-actions">
        <button class="dm-btn dm-btn-outline" @onclick="CargarAsync" disabled="@_cargando">
            🔄 Actualizar
        </button>
    </div>
</div>

<!-- Filtros por tipo -->
<div class="dm-tabs-row">
    @foreach (var tipo in _tipos)
    {
        var count = tipo == "TODOS"
            ? _todasLasReglas.Count
            : _todasLasReglas.Count(r => r.Tipo == tipo);
        <button class="dm-tab @(_filtroTipo == tipo ? "dm-tab-active" : "")"
                @onclick="() => _filtroTipo = tipo">
            @TipoIcon(tipo) @tipo
            <span class="dm-tab-count">@count</span>
        </button>
    }
</div>

@if (_errorMensaje != null)
{
    <div class="dm-error-banner"><span>⚠</span> @_errorMensaje</div>
}

@if (_mensajeOk != null)
{
    <div class="dm-ok-banner"><span>✓</span> @_mensajeOk</div>
}

@if (_cargando)
{
    <div class="dm-loading-container">
        <div class="dm-spinner"></div>
        <p>Cargando reglas...</p>
    </div>
}
else if (!ReglasFiltradas.Any())
{
    <div class="dm-empty-state">
        <div class="dm-empty-icon">⚙️</div>
        <h3 class="dm-empty-title">Sin reglas para este tipo</h3>
    </div>
}
else
{
    <div class="dm-table-container">
        <table class="dm-table">
            <thead>
                <tr>
                    <th>Tipo</th>
                    <th>Código</th>
                    <th>Nombre</th>
                    <th style="text-align:center">Prio.</th>
                    <th style="text-align:center">Activo</th>
                    <th style="text-align:center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var regla in ReglasFiltradas)
                {
                    <tr class="@(!regla.Activo ? "dm-row-inactivo" : "")">
                        <td>
                            <span class="dm-tipo-badge @TipoBadgeClase(regla.Tipo)">
                                @TipoIcon(regla.Tipo) @regla.Tipo
                            </span>
                        </td>
                        <td>
                            <span class="dm-codigo-badge">@regla.Codigo</span>
                        </td>
                        <td class="dm-nombre-cell">
                            @regla.Nombre
                            @if (!string.IsNullOrEmpty(regla.Severidad))
                            {
                                <span class="dm-severidad-badge @SeveridadClase(regla.Severidad)">@regla.Severidad</span>
                            }
                        </td>
                        <td style="text-align:center">
                            <span class="dm-prio-num">@regla.Prioridad</span>
                        </td>
                        <td style="text-align:center">
                            @if (_esAdmin)
                            {
                                <button class="dm-toggle @(regla.Activo ? "dm-toggle-on" : "dm-toggle-off")"
                                        @onclick="() => ToggleActivoAsync(regla)"
                                        title="@(regla.Activo ? "Desactivar" : "Activar")">
                                    @(regla.Activo ? "ON" : "OFF")
                                </button>
                            }
                            else
                            {
                                <span class="dm-toggle-readonly @(regla.Activo ? "dm-toggle-on" : "dm-toggle-off")">
                                    @(regla.Activo ? "ON" : "OFF")
                                </span>
                            }
                        </td>
                        <td style="text-align:center">
                            <button class="dm-btn dm-btn-xs dm-btn-outline"
                                    @onclick="() => AbrirEdicion(regla)">
                                @(_esAdmin ? "✏️ Editar" : "👁 Ver")
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Modal edición / vista -->
@if (_modalEdicion && _reglaEditando != null)
{
    <div class="dm-modal-overlay" @onclick="CerrarModal">
        <div class="dm-modal dm-modal-lg" @onclick:stopPropagation>
            <div class="dm-modal-header">
                <div>
                    <h3>@(_esAdmin ? "Editar" : "Ver") regla</h3>
                    <span class="dm-modal-subtitle">
                        <span class="dm-tipo-badge @TipoBadgeClase(_reglaEditando.Tipo)">
                            @TipoIcon(_reglaEditando.Tipo) @_reglaEditando.Tipo
                        </span>
                        <span class="dm-codigo-badge">@_reglaEditando.Codigo</span>
                    </span>
                </div>
                <button class="dm-modal-close" @onclick="CerrarModal">✕</button>
            </div>

            <div class="dm-modal-body">
                <div class="dm-modal-nombre">@_reglaEditando.Nombre</div>

                <div class="dm-edit-grid">
                    <div class="dm-field-group">
                        <label>Prioridad</label>
                        @if (_esAdmin)
                        {
                            <input type="number" @bind="_editPrioridad" class="dm-input dm-input-sm"
                                   min="1" max="9999" />
                        }
                        else
                        {
                            <span class="dm-readonly-val">@_editPrioridad</span>
                        }
                    </div>

                    @if (_reglaEditando.Tipo == "ALERTA")
                    {
                        <div class="dm-field-group">
                            <label>Severidad</label>
                            @if (_esAdmin)
                            {
                                <select @bind="_editSeveridad" class="dm-select dm-select-sm">
                                    <option value="CRITICA">CRITICA</option>
                                    <option value="ALTA">ALTA</option>
                                    <option value="MEDIA">MEDIA</option>
                                </select>
                            }
                            else
                            {
                                <span class="dm-readonly-val @SeveridadClase(_editSeveridad)">@_editSeveridad</span>
                            }
                        </div>
                    }

                    <div class="dm-field-group">
                        <label>Activo</label>
                        @if (_esAdmin)
                        {
                            <label class="dm-switch-label">
                                <input type="checkbox" @bind="_editActivo" class="dm-checkbox" />
                                @(_editActivo ? "Sí" : "No")
                            </label>
                        }
                        else
                        {
                            <span class="dm-readonly-val">@(_editActivo ? "Sí" : "No")</span>
                        }
                    </div>

                    <div class="dm-field-group">
                        <label>Versión</label>
                        <span class="dm-readonly-val">v@_reglaEditando.Version</span>
                    </div>
                </div>

                <div class="dm-field-group" style="margin-top: 0.75rem;">
                    <label>Condiciones JSON</label>
                    @if (_esAdmin)
                    {
                        <textarea @bind="_editCondicionesJson" class="dm-textarea dm-textarea-code"
                                  rows="8" spellcheck="false"></textarea>
                        @if (_jsonCondError != null)
                        {
                            <span class="dm-json-error">@_jsonCondError</span>
                        }
                    }
                    else
                    {
                        <pre class="dm-pre-json">@FormatJson(_reglaEditando.CondicionesJson)</pre>
                    }
                </div>

                <div class="dm-field-group">
                    <label>Acción JSON</label>
                    @if (_esAdmin)
                    {
                        <textarea @bind="_editAccionJson" class="dm-textarea dm-textarea-code"
                                  rows="5" spellcheck="false"></textarea>
                        @if (_jsonAccionError != null)
                        {
                            <span class="dm-json-error">@_jsonAccionError</span>
                        }
                    }
                    else
                    {
                        <pre class="dm-pre-json">@FormatJson(_reglaEditando.AccionJson)</pre>
                    }
                </div>

                @if (_modalError != null)
                {
                    <div class="dm-modal-error">⚠ @_modalError</div>
                }
            </div>

            <div class="dm-modal-footer">
                <button class="dm-btn dm-btn-outline" @onclick="CerrarModal" disabled="@_guardando">
                    @(_esAdmin ? "Cancelar" : "Cerrar")
                </button>
                @if (_esAdmin)
                {
                    <button class="dm-btn dm-btn-primary" @onclick="GuardarAsync" disabled="@_guardando">
                        @if (_guardando) { <span class="dm-spinner-sm"></span> }
                        💾 Guardar
                    </button>
                }
            </div>
        </div>
    </div>
}

<style>
