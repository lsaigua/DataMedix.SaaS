    .dm-modal-error { background: #fee2e2; color: #991b1b; border-radius: 8px;
                      padding: 0.625rem 0.875rem; font-size: 0.825rem; font-weight: 500; }

    .dm-edit-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 0.75rem; }
    .dm-field-group { display: flex; flex-direction: column; gap: 0.3rem; }
    .dm-field-group > label { font-size: 0.7rem; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.04em; }
    .dm-input { border: 1.5px solid #e2e8f0; border-radius: 8px; padding: 0.5rem 0.75rem;
                font-size: 0.875rem; color: #374151; background: white; outline: none; }
    .dm-input-sm { padding: 0.35rem 0.6rem; font-size: 0.825rem; }
    .dm-input:focus { border-color: #0ea5e9; }
    .dm-select { border: 1.5px solid #e2e8f0; border-radius: 8px; padding: 0.5rem 0.75rem;
                 font-size: 0.875rem; color: #374151; background: white; cursor: pointer; outline: none; }
    .dm-select-sm { padding: 0.35rem 0.6rem; font-size: 0.825rem; }
    .dm-select:focus { border-color: #0ea5e9; }
    .dm-textarea { border: 1.5px solid #e2e8f0; border-radius: 8px; padding: 0.5rem 0.75rem;
                   font-size: 0.875rem; color: #374151; background: white; outline: none;
                   resize: vertical; width: 100%; box-sizing: border-box; }
