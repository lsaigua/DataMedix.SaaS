    .dm-modal-lg { max-width: 720px; }
    .dm-modal-header { padding: 1.25rem 1.5rem; border-bottom: 1px solid #f1f5f9;
                       display: flex; justify-content: space-between; align-items: flex-start; }
    .dm-modal-header h3 { margin: 0; font-size: 1.1rem; font-weight: 800; color: #1e293b; }
    .dm-modal-subtitle { font-size: 0.8rem; color: #64748b; margin-top: 0.35rem; display: flex; gap: 0.4rem; flex-wrap: wrap; }
