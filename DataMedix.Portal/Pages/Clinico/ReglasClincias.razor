                       font-weight: 600; color: #374151; cursor: pointer; }
    .dm-json-error { font-size: 0.75rem; color: #dc2626; font-weight: 500; }
</style>

@code {
    private List<ReglaClinica> _todasLasReglas = new();
    private string _filtroTipo = "TODOS";
    private bool _cargando = true;
    private string? _errorMensaje;
    private string? _mensajeOk;
    private bool _esAdmin;

    private readonly string[] _tipos = ["TODOS", "EPO", "HIERRO", "ALERTA", "MODIFICADOR"];

    // Modal
    private ReglaClinica? _reglaEditando;
    private bool _modalEdicion;
    private bool _guardando;
    private int _editPrioridad;
    private bool _editActivo;
    private string _editSeveridad = "";
    private string _editCondicionesJson = "";
    private string _editAccionJson = "";
    private string? _modalError;
    private string? _jsonCondError;
    private string? _jsonAccionError;

    private static readonly JsonSerializerOptions _jsonIndented = new() { WriteIndented = true };

    private IEnumerable<ReglaClinica> ReglasFiltradas =>
        _filtroTipo == "TODOS"
            ? _todasLasReglas
            : _todasLasReglas.Where(r => r.Tipo == _filtroTipo);

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var rol = auth.User.FindFirst(ClaimTypes.Role)?.Value ?? "";
        _esAdmin = rol is "SUPERADMIN" or "ADMIN";
        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        _cargando = true;
        _errorMensaje = null;
        _mensajeOk = null;
        StateHasChanged();

        try
        {
            _todasLasReglas = (await ReglaRepo.GetAllAsync()).ToList();
        }
        catch (Exception ex)
        {
            _errorMensaje = ex.Message;
            _todasLasReglas = [];
        }
        finally
        {
            _cargando = false;
        }
    }

    private void AbrirEdicion(ReglaClinica regla)
    {
        _reglaEditando = regla;
        _editPrioridad = regla.Prioridad;
        _editActivo = regla.Activo;
        _editSeveridad = regla.Severidad ?? "MEDIA";
        _editCondicionesJson = FormatJson(regla.CondicionesJson);
        _editAccionJson = FormatJson(regla.AccionJson);
        _modalError = null;
        _jsonCondError = null;
        _jsonAccionError = null;
        _modalEdicion = true;
    }

    private void CerrarModal()
    {
        if (_guardando) return;
        _modalEdicion = false;
        _reglaEditando = null;
    }

    private async Task ToggleActivoAsync(ReglaClinica regla)
    {
        _mensajeOk = null;
        _errorMensaje = null;

        try
        {
            regla.Activo = !regla.Activo;
            await ReglaRepo.UpdateAsync(regla);
            RuleCache.Invalidate();
            _mensajeOk = $"Regla {regla.Codigo} {(regla.Activo ? "activada" : "desactivada")}.";
        }
        catch (Exception ex)
        {
            regla.Activo = !regla.Activo; // revert
            _errorMensaje = ex.Message;
        }

        StateHasChanged();
    }

    private async Task GuardarAsync()
    {
        if (_reglaEditando == null) return;

        _jsonCondError = null;
        _jsonAccionError = null;
        _modalError = null;

        if (!ValidarJson(_editCondicionesJson, out _jsonCondError)) return;
        if (!ValidarJson(_editAccionJson, out _jsonAccionError)) return;

        _guardando = true;
        StateHasChanged();

        try
        {
            _reglaEditando.Prioridad      = _editPrioridad;
            _reglaEditando.Activo         = _editActivo;
            _reglaEditando.Severidad      = _reglaEditando.Tipo == "ALERTA" ? _editSeveridad : _reglaEditando.Severidad;
            _reglaEditando.CondicionesJson = _editCondicionesJson.Trim();
            _reglaEditando.AccionJson      = _editAccionJson.Trim();

            await ReglaRepo.UpdateAsync(_reglaEditando);
            RuleCache.Invalidate();

            _modalEdicion = false;
            _mensajeOk = $"Regla {_reglaEditando.Codigo} guardada. Caché invalidada.";
        }
        catch (Exception ex)
        {
            _modalError = ex.Message;
        }
        finally
        {
            _guardando = false;
        }
    }

    private static bool ValidarJson(string json, out string? error)
    {
        error = null;
        if (string.IsNullOrWhiteSpace(json))
        {
            error = "El JSON no puede estar vacío.";
            return false;
        }
        try
        {
            JsonDocument.Parse(json);
            return true;
        }
        catch (JsonException ex)
        {
            error = $"JSON inválido: {ex.Message}";
            return false;
        }
    }

    private static string FormatJson(string? json)
    {
        if (string.IsNullOrEmpty(json)) return "";
        try
        {
            var doc = JsonDocument.Parse(json);
            return JsonSerializer.Serialize(doc, _jsonIndented);
        }
        catch { return json; }
    }

    private static string TipoIcon(string tipo) => tipo switch
    {
        "EPO"         => "💉",
        "HIERRO"      => "🔬",
        "ALERTA"      => "🚨",
        "MODIFICADOR" => "⚙️",
        _             => "📋"
    };

    private static string TipoBadgeClase(string tipo) => tipo switch
    {
        "EPO"         => "dm-tipo-epo",
        "HIERRO"      => "dm-tipo-hierro",
        "ALERTA"      => "dm-tipo-alerta",
        "MODIFICADOR" => "dm-tipo-modificador",
        _             => ""
    };

    private static string SeveridadClase(string? sev) => sev switch
    {
        "CRITICA" => "dm-sev-critica",
        "ALTA"    => "dm-sev-alta",
        _         => "dm-sev-media"
    };
}
