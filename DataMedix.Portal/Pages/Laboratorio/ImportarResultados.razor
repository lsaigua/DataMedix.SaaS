    .dm-stat-total { border-left: 3px solid #0ea5e9; }
    .dm-stat-value { font-size: 1.75rem; font-weight: 800; color: #1e293b; }
    .dm-stat-label { font-size: 0.75rem; color: #64748b; font-weight: 500; }
