    /* Resultado */
    .dm-resultado-icon { font-size: 4rem; margin-bottom: 1rem; }
    .dm-resultado-titulo { font-size: 1.5rem; font-weight: 800; color: #1e293b; margin-bottom: 1.5rem; }
