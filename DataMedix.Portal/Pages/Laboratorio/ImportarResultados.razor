    .dm-file-icon { font-size: 1.25rem; }
    .dm-file-name { font-weight: 600; color: #1e293b; }
    .dm-file-size { color: #94a3b8; font-size: 0.85rem; }

    /* Info box */
    .dm-info-box { background: #f8fafc; border-radius: 12px; padding: 1.25rem 1.5rem;
                   border: 1px solid #e2e8f0; margin-top: 1.5rem; }
    .dm-info-box h4 { font-size: 0.9rem; color: #374151; margin: 0 0 1rem; font-weight: 700; }
    .dm-columns-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 0.5rem; }
    .dm-col-item { display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; color: #4b5563; }
