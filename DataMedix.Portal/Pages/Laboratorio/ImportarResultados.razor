    .dm-resultado-acciones { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
</style>

@code {
    private int Paso = 1;
    private bool Procesando = false;
    private bool ArrastreSobre = false;
    private string NombreArchivo = string.Empty;
    private string TamanoArchivo = string.Empty;
    private IBrowserFile? ArchivoSeleccionado;
    private MemoryStream? _archivoMs;   // archivo cacheado en memoria tras selección
    private PreVisualizacionDto? Preview;
    private ImportacionResultadoDto? Resultado;

    private Guid TenantId;
    private Guid UsuarioId;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var tenantStr = auth.User.FindFirst("tenant_id")?.Value;
        var userStr = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        TenantId = Guid.TryParse(tenantStr, out var t) ? t : Guid.Empty;
        UsuarioId = Guid.TryParse(userStr, out var u) ? u : Guid.Empty;
    }

    private async Task HandleFileSeleccionado(InputFileChangeEventArgs e)
    {
        ArchivoSeleccionado = e.File;
        NombreArchivo = e.File.Name;
        TamanoArchivo = FormatearTamano(e.File.Size);
        Preview = null;
        Resultado = null;

        // Copiar a MemoryStream AQUÍ, mientras el browser file reference aún es válido
        // y antes de cualquier StateHasChanged() que destruiría _blazorFilesById.
        _archivoMs?.Dispose();
        _archivoMs = null;
        try
        {
            using var browserStream = e.File.OpenReadStream(maxAllowedSize: 50_000_000);
            _archivoMs = new MemoryStream();
            await browserStream.CopyToAsync(_archivoMs);
        }
        catch (Exception ex)
        {
            GlobalToastService.ShowError($"Error leyendo el archivo: {ex.Message}");
            ArchivoSeleccionado = null;
            NombreArchivo = string.Empty;
        }
    }

    private async Task PrevisualizarArchivo()
    {
        if (_archivoMs == null) return;

        if (!NombreArchivo.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase))
        {
            GlobalToastService.ShowError("Solo se permiten archivos .xlsx");
            return;
        }

        Procesando = true;
        StateHasChanged();

        try
        {
            _archivoMs.Position = 0;
            Preview = await ImportacionSvc.PrevisualizarAsync(_archivoMs, TenantId);
            Paso = 2;
        }
        catch (Exception ex)
        {
            GlobalToastService.ShowError($"Error al previsualizar: {ex.Message}");
        }
        finally
        {
            Procesando = false;
        }
    }

    private async Task ConfirmarProcesamiento()
    {
        if (_archivoMs == null) return;

        Procesando = true;
        GlobalLoadingService.Show("Procesando archivo clínico...");
        StateHasChanged();

        try
        {
            _archivoMs.Position = 0;
            Resultado = await ImportacionSvc.ProcesarAsync(
                _archivoMs, NombreArchivo, TenantId, UsuarioId);

            if (Resultado.Exitoso)
                GlobalToastService.ShowSuccess($"✅ {Resultado.FilasValidas} resultado(s) importados correctamente.");
            else
                GlobalToastService.ShowError(Resultado.MensajeError ?? "Error al procesar.");

            Paso = 3;
        }
        catch (Exception ex)
        {
            GlobalToastService.ShowError($"Error inesperado: {ex.Message}");
        }
        finally
        {
            Procesando = false;
            GlobalLoadingService.Hide();
        }
    }

    private void ReiniciarPaso()
    {
        Paso = 1;
        NombreArchivo = string.Empty;
        TamanoArchivo = string.Empty;
        ArchivoSeleccionado = null;
        _archivoMs?.Dispose();
        _archivoMs = null;
        Preview = null;
        Resultado = null;
        ArrastreSobre = false;
    }

    private bool FilaTieneError(int numeroFila) =>
        Preview?.Errores.Any(e => e.NumeroFila == numeroFila) ?? false;

    private void DescargarErrores()
    {
        // TODO: implementar descarga CSV de errores
        GlobalToastService.ShowWarning("Descarga de errores: próximamente disponible.");
    }

    private static string FormatearTamano(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1_048_576) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / 1_048_576.0:F1} MB";
    }

    public void Dispose() => _archivoMs?.Dispose();
}
