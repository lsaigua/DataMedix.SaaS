                    white-space: nowrap; align-self: flex-end; }
    .dm-btn-clear:hover { background: #fca5a5; }
</style>

@code {
    [Parameter] public Guid? PacienteId { get; set; }

    private List<SnapshotMensual> Snapshots = new();
    private List<string> PlanesSalud = new();
    private Paciente? PacienteSeleccionado;
    private bool Cargando = true;
    private string BusquedaTexto = string.Empty;
    private int FiltroMes = DateTime.Now.Month;
    private int FiltroAnio = DateTime.Now.Year;
    private string FiltroPlanSalud = string.Empty;
    private Guid TenantId;
    private System.Threading.CancellationTokenSource? _debounce;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var tenantStr = auth.User.FindFirst("tenant_id")?.Value;
        TenantId = Guid.TryParse(tenantStr, out var t) ? t : Guid.Empty;

        if (PacienteId.HasValue)
            PacienteSeleccionado = await PacienteRepo.GetByIdAsync(TenantId, PacienteId.Value);

        await CargarSnapshotsAsync();
    }

    private async Task CargarSnapshotsAsync()
    {
        Cargando = true;
        StateHasChanged();

        try
        {
            if (PacienteId.HasValue)
            {
                Snapshots = await SnapshotRepo.GetHistorialAsync(TenantId, PacienteId.Value, 24);
            }
            else
            {
                var periodDate = FiltroMes > 0
                    ? new DateTime(FiltroAnio, FiltroMes, 1, 0, 0, 0, DateTimeKind.Utc)
                    : new DateTime(FiltroAnio, DateTime.Now.Month, 1, 0, 0, 0, DateTimeKind.Utc);

                PlanesSalud = await SnapshotRepo.GetPlanesSaludAsync(TenantId, periodDate);
                Snapshots = await SnapshotRepo.GetByPeriodoAsync(
                    TenantId, periodDate, BusquedaTexto, planSalud: FiltroPlanSalud);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando snapshots: {ex.Message}");
            Snapshots = new();
        }
        finally
        {
            Cargando = false;
        }
    }

    private async Task BuscarDebounced()
    {
        _debounce?.Cancel();
        _debounce = new System.Threading.CancellationTokenSource();
        var token = _debounce.Token;
        await Task.Delay(400, token).ContinueWith(async t =>
        {
            if (t.IsCompletedSuccessfully)
                await InvokeAsync(CargarSnapshotsAsync);
        });
    }

    private async Task LimpiarFiltros()
    {
        FiltroPlanSalud = string.Empty;
        await CargarSnapshotsAsync();
    }

    private static string ClaseValor(decimal valor, decimal min, decimal max) =>
        valor < min ? "dm-valor-bajo" : valor > max ? "dm-valor-alto" : "dm-valor-ok";
}
