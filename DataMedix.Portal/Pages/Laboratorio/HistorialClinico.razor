    .dm-btn { padding: 0.625rem 1.25rem; border-radius: 8px; font-weight: 600; font-size: 0.875rem;
              text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; cursor: pointer; border: none; }
    .dm-btn-primary { background: #0ea5e9; color: white; }
    .dm-btn-primary:hover { background: #0284c7; color: white; }

    .dm-page-actions { display: flex; gap: 0.75rem; }

    .dm-btn-clear { background: #fee2e2; color: #dc2626; border: 1px solid #fca5a5;
