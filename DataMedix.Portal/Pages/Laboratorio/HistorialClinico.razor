@page "/historial-clinico"
@page "/historial-clinico/{PacienteId:guid}"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using DataMedix.Application.Interfaces
@using DataMedix.Domain.Entities
@using System.Security.Claims

@inject ISnapshotMensualRepository SnapshotRepo
@inject IPacienteRepository PacienteRepo
@inject AuthenticationStateProvider AuthState

<PageTitle>Historial Clínico | DataMedix</PageTitle>

<div class="dm-page-header">
    <div>
        <h1 class="dm-page-title">Historial Clínico Mensual</h1>
        @if (PacienteSeleccionado != null)
        {
            <p class="dm-page-subtitle">
                @PacienteSeleccionado.NombreCompleto —
                <span class="dm-ident-badge">@PacienteSeleccionado.Identificacion</span>
            </p>
        }
        else
        {
            <p class="dm-page-subtitle">Resultados clínicos agrupados por mes/año</p>
        }
    </div>
    <div class="dm-page-actions">
        <a href="/laboratorio/importar" class="dm-btn dm-btn-primary">📤 Nueva Carga</a>
    </div>
</div>

<!-- Filtros -->
<div class="dm-filters-bar">
    <div class="dm-search-box">
        <span>🔍</span>
        <input type="text" placeholder="Buscar paciente por nombre o cédula..."
               @bind="BusquedaTexto" @bind:event="oninput" @onkeyup="BuscarDebounced"
               class="dm-search-input" />
    </div>

    <div class="dm-filter-group">
        <label>Mes</label>
        <select @bind="FiltroMes" @bind:after="CargarSnapshotsAsync" class="dm-select">
            <option value="0">Todos</option>
            @for (int m = 1; m <= 12; m++)
            {
                <option value="@m">@(new DateTime(2000, m, 1).ToString("MMMM"))</option>
            }
        </select>
    </div>

    <div class="dm-filter-group">
        <label>Año</label>
        <select @bind="FiltroAnio" @bind:after="CargarSnapshotsAsync" class="dm-select">
            @for (int a = DateTime.Now.Year; a >= DateTime.Now.Year - 3; a--)
            {
                <option value="@a">@a</option>
            }
        </select>
    </div>

    <div class="dm-filter-group">
        <label>Plan Salud</label>
        <select @bind="FiltroPlanSalud" @bind:after="CargarSnapshotsAsync" class="dm-select">
            <option value="">Todos</option>
            @foreach (var plan in PlanesSalud)
            {
                <option value="@plan">@plan</option>
            }
        </select>
    </div>

    @if (!string.IsNullOrEmpty(FiltroPlanSalud))
    {
        <button class="dm-btn-clear" @onclick="LimpiarFiltros" title="Limpiar filtros">
            ✕ Limpiar filtros
        </button>
    }
</div>

@if (Cargando)
{
    <div class="dm-loading-container">
        <div class="dm-spinner"></div>
        <p>Cargando historial clínico...</p>
    </div>
}
else if (!Snapshots.Any())
{
    <div class="dm-empty-state">
        <div class="dm-empty-icon">📈</div>
        <h3 class="dm-empty-title">Sin resultados para el período</h3>
        <p class="dm-empty-desc">No hay datos clínicos para el filtro seleccionado.</p>
        <a href="/laboratorio/importar" class="dm-btn dm-btn-primary">📤 Importar Resultados</a>
    </div>
}
else
{
    <div class="dm-card">
        <div class="dm-table-responsive">
            <table class="dm-table">
                <thead>
                    <tr>
                        <th>Paciente</th>
                        <th>Período</th>
                        <th class="dm-th-param">
                            <span class="dm-param-badge dm-param-hb">HB (g/dL)</span>
                        </th>
                        <th class="dm-th-param">
                            <span class="dm-param-badge dm-param-fe">Hierro (ug/dL)</span>
                        </th>
                        <th class="dm-th-param">
                            <span class="dm-param-badge dm-param-ferr">Ferritina (ng/mL)</span>
                        </th>
                        <th class="dm-th-param">
                            <span class="dm-param-badge dm-param-isat">ISAT (%)</span>
                        </th>
                        <th>Plan Salud</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var snap in Snapshots)
                    {
                        <tr class="@(snap.EsDatosPeriodoAnterior ? "dm-row-anterior" : "")">
                            <td>
                                <div class="dm-paciente-cell">
                                    <div class="dm-avatar">@snap.Paciente?.PrimerNombre?.FirstOrDefault()</div>
                                    <div>
                                        <div class="dm-nombre">@snap.Paciente?.NombreCompleto</div>
                                        <div class="dm-ident-small">@snap.Paciente?.Identificacion</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="dm-periodo">
                                    <span class="dm-mes">@snap.PeriodDate.ToString("MMM yyyy")</span>
                                    @if (snap.EsDatosPeriodoAnterior)
                                    {
                                        <span class="dm-badge-prev" title="Usando datos del período anterior">↩</span>
                                    }
                                </div>
                            </td>
                            <td class="dm-td-param">
                                @if (snap.HbValor.HasValue)
                                {
                                    <span class="@ClaseValor(snap.HbValor.Value, 10m, 12m)">
                                        @snap.HbValor.Value.ToString("F1")
                                    </span>
                                }
                                else { <span class="dm-sin-dato">—</span> }
                            </td>
                            <td class="dm-td-param">
                                @if (snap.HierroValor.HasValue)
                                {
                                    <span class="@ClaseValor(snap.HierroValor.Value, 60m, 170m)">
                                        @snap.HierroValor.Value.ToString("F0")
                                    </span>
                                }
                                else { <span class="dm-sin-dato">—</span> }
                            </td>
                            <td class="dm-td-param">
                                @if (snap.FerritinaValor.HasValue)
                                {
                                    <span class="@ClaseValor(snap.FerritinaValor.Value, 200m, 500m)">
                                        @snap.FerritinaValor.Value.ToString("F0")
                                    </span>
                                }
                                else { <span class="dm-sin-dato">—</span> }
                            </td>
                            <td class="dm-td-param">
                                @if (snap.SaturacionValor.HasValue)
                                {
                                    <span class="@ClaseValor(snap.SaturacionValor.Value, 20m, 50m)">
                                        @snap.SaturacionValor.Value.ToString("F1")%
                                    </span>
                                }
                                else { <span class="dm-sin-dato">—</span> }
                            </td>
                            <td>@(snap.PlanSalud ?? "—")</td>
                            <td>
                                <div class="dm-acciones">
                                    <a href="/prescripciones/@snap.PacienteId" class="dm-btn-icon"
                                       title="Ver prescripción">💊</a>
                                    <a href="/historial-clinico/@snap.PacienteId" class="dm-btn-icon"
                                       title="Historial completo">📋</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Leyenda -->
        <div class="dm-legend">
            <span class="dm-legend-item">
                <span class="dm-valor-ok">■</span> En rango objetivo
            </span>
            <span class="dm-legend-item">
                <span class="dm-valor-bajo">■</span> Por debajo del rango
            </span>
            <span class="dm-legend-item">
                <span class="dm-valor-alto">■</span> Por encima del rango
            </span>
            <span class="dm-legend-item">
                <span class="dm-badge-prev">↩</span> Datos del mes anterior
            </span>
        </div>
    </div>
}

<style>
