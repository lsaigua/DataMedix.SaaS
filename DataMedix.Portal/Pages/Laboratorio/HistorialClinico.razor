    .dm-param-fe { background: #fef3c7; color: #92400e; }
    .dm-param-ferr { background: #ecfdf5; color: #065f46; }
    .dm-param-isat { background: #eff6ff; color: #1d4ed8; }

    .dm-valor-ok { color: #059669; font-size: 0.9rem; font-weight: 700; }
    .dm-valor-bajo { color: #dc2626; font-size: 0.9rem; font-weight: 700; }
    .dm-valor-alto { color: #d97706; font-size: 0.9rem; font-weight: 700; }
    .dm-sin-dato { color: #cbd5e1; font-size: 0.85rem; }

    .dm-paciente-cell { display: flex; align-items: center; gap: 0.75rem; }
