@page "/test-ui"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@inject DataMedix.Portal.Services.GlobalLoadingService GlobalLoadingService
@inject DataMedix.Portal.Services.GlobalToastService GlobalToastService

<h3>Prueba UI Global</h3>

<div style="display:flex; gap:10px;">
    <button type="button" class="btn-primary" @onclick="PruebaLoading">Probar Loading</button>
    <button type="button" class="btn-primary" @onclick="PruebaToast">Probar Toast</button>
</div>

@code {
    private async Task PruebaLoading()
    {
        GlobalLoadingService.Show("Cargando prueba global...");
        await InvokeAsync(StateHasChanged);

        await Task.Delay(2000);

        GlobalLoadingService.Hide();
        await InvokeAsync(StateHasChanged);
    }

    private void PruebaToast()
    {
        GlobalToastService.ShowSuccess("Toast global OK.");
    }
}