    .dm-sin-ref { color: #cbd5e1; font-style: italic; }

    .dm-badge { padding: 0.2rem 0.5rem; border-radius: 12px; font-size: 0.7rem; font-weight: 700; white-space: nowrap; }
    .dm-badge-pato { background: #fee2e2; color: #991b1b; }
    .dm-badge-normal { background: #dcfce7; color: #166534; }

    .dm-periodo-badge { background: #f1f5f9; color: #475569; padding: 0.2rem 0.55rem;
                        border-radius: 6px; font-size: 0.75rem; font-weight: 700; white-space: nowrap; }
