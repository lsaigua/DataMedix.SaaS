    .dm-pagination { display: flex; justify-content: space-between; align-items: center;
                     padding: 0.875rem 1rem; border-top: 1px solid #f1f5f9; background: #f8fafc; gap: 0.5rem; }
    .dm-pagination-pages { display: flex; gap: 0.25rem; align-items: center; }
    .dm-btn-pag-active { background: #0ea5e9 !important; color: white !important; border-color: #0ea5e9 !important; }
    .dm-pag-ellipsis { color: #94a3b8; font-size: 0.85rem; padding: 0 0.25rem; }

    .dm-loading-container { display: flex; flex-direction: column; align-items: center; padding: 4rem 2rem; color: #64748b; gap: 1rem; }
    .dm-spinner { width: 40px; height: 40px; border: 3px solid #e2e8f0; border-top-color: #0ea5e9;
                  border-radius: 50%; animation: spin 0.8s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }

    .dm-empty-state { text-align: center; padding: 4rem 2rem; color: #64748b; }
    .dm-empty-icon { font-size: 3rem; margin-bottom: 1rem; }
    .dm-empty-title { font-size: 1.2rem; font-weight: 700; color: #374151; margin-bottom: 0.5rem; }
    .dm-empty-desc { font-size: 0.9rem; margin-bottom: 1.5rem; }

    .dm-error-banner { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; border-radius: 8px;
                       padding: 0.875rem 1rem; margin-bottom: 1rem; display: flex; gap: 0.5rem;
                       align-items: center; font-size: 0.875rem; font-weight: 500; }
</style>

@code {
    private List<ResultadoLaboratorio> Resultados = new();
    private List<ParametroClinico> Parametros = new();
    private List<LoteImportacion> Lotes = new();
    private ResultadoFiltro Filtro = new();
    private string BusquedaPaciente = string.Empty;
    private int Total = 0;
    private string? ErrorMensaje;
    private int TotalPaginas => Total == 0 ? 1 : (int)Math.Ceiling(Total / (double)Filtro.Tamano);
    private bool Cargando = true;
    private Guid TenantId;
    private System.Timers.Timer? _debounceTimer;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var tenantStr = auth.User.FindFirst("tenant_id")?.Value;
        TenantId = Guid.TryParse(tenantStr, out var t) ? t : Guid.Empty;

        try
        {
            Parametros = await ParametroRepo.GetAllAsync();
            Lotes = await LoteRepo.GetByTenantAsync(TenantId, 1, 100);
            (Resultados, Total) = await ResultadoRepo.GetPagedAsync(TenantId, Filtro);
        }
        catch (Exception ex)
        {
            ErrorMensaje = ex.Message;
        }
        finally
        {
            Cargando = false;
        }
    }

    private async Task CargarAsync()
    {
        Cargando = true;
        ErrorMensaje = null;
        StateHasChanged();
        try
        {
            (Resultados, Total) = await ResultadoRepo.GetPagedAsync(TenantId, Filtro);
        }
        catch (Exception ex)
        {
            ErrorMensaje = ex.Message;
        }
        finally
        {
            Cargando = false;
        }
    }

    private void BuscarDebounced(KeyboardEventArgs _)
    {
        Filtro.BusquedaPaciente = BusquedaPaciente;
        Filtro.Pagina = 1;
        _debounceTimer?.Dispose();
        _debounceTimer = new System.Timers.Timer(350);
        _debounceTimer.Elapsed += async (_, _) =>
        {
            _debounceTimer?.Dispose();
            await InvokeAsync(CargarAsync);
        };
        _debounceTimer.AutoReset = false;
        _debounceTimer.Start();
    }

    private async Task PaginaAnterior()
    {
        if (Filtro.Pagina <= 1) return;
        Filtro.Pagina--;
        await CargarAsync();
    }

    private async Task PaginaSiguiente()
    {
        if (Filtro.Pagina >= TotalPaginas) return;
        Filtro.Pagina++;
        await CargarAsync();
    }

    private async Task IrAPagina(int pagina)
    {
        Filtro.Pagina = pagina;
        await CargarAsync();
    }

    private async Task OnParametroChange(ChangeEventArgs e)
    {
        Filtro.ParametroClinicoId = Guid.TryParse(e.Value?.ToString(), out var g) ? g : null;
        Filtro.Pagina = 1;
        await CargarAsync();
    }

    private async Task OnMesDesdeChange(ChangeEventArgs e)
    {
        Filtro.MesDe = int.TryParse(e.Value?.ToString(), out var i) ? i : null;
        Filtro.Pagina = 1;
        await CargarAsync();
    }

    private async Task OnAnioDesdeChange(ChangeEventArgs e)
    {
        Filtro.AnioDe = int.TryParse(e.Value?.ToString(), out var i) ? i : null;
        Filtro.Pagina = 1;
        await CargarAsync();
    }

    private async Task OnMesHastaChange(ChangeEventArgs e)
    {
        Filtro.MesHasta = int.TryParse(e.Value?.ToString(), out var i) ? i : null;
        Filtro.Pagina = 1;
        await CargarAsync();
    }

    private async Task OnAnioHastaChange(ChangeEventArgs e)
    {
        Filtro.AnioHasta = int.TryParse(e.Value?.ToString(), out var i) ? i : null;
        Filtro.Pagina = 1;
        await CargarAsync();
    }

    private async Task OnLoteChange(ChangeEventArgs e)
    {
        Filtro.LoteId = Guid.TryParse(e.Value?.ToString(), out var g) ? g : null;
        Filtro.Pagina = 1;
        await CargarAsync();
    }

    private async Task LimpiarFiltros()
    {
        Filtro = new ResultadoFiltro();
        BusquedaPaciente = string.Empty;
        await CargarAsync();
    }

    private void ExportarExcel()
    {
        var qs = new List<string>();
        if (!string.IsNullOrWhiteSpace(Filtro.BusquedaPaciente))
            qs.Add($"busquedaPaciente={Uri.EscapeDataString(Filtro.BusquedaPaciente)}");
        if (Filtro.ParametroClinicoId.HasValue)
            qs.Add($"parametroClinicoId={Filtro.ParametroClinicoId}");
        if (Filtro.AnioDe.HasValue)   qs.Add($"anioDe={Filtro.AnioDe}");
        if (Filtro.MesDe.HasValue)    qs.Add($"mesDe={Filtro.MesDe}");
        if (Filtro.AnioHasta.HasValue) qs.Add($"anioHasta={Filtro.AnioHasta}");
        if (Filtro.MesHasta.HasValue)  qs.Add($"mesHasta={Filtro.MesHasta}");
        if (Filtro.LoteId.HasValue)   qs.Add($"loteId={Filtro.LoteId}");

        var url = "/api/reportes/resultados-excel" + (qs.Any() ? "?" + string.Join("&", qs) : "");
        Nav.NavigateTo(url, forceLoad: true);
    }

    private static string TruncNombre(string? s, int max)
    {
        if (string.IsNullOrEmpty(s)) return "—";
        return s.Length > max ? s[..max] + "…" : s;
    }

    public void Dispose() => _debounceTimer?.Dispose();
}
