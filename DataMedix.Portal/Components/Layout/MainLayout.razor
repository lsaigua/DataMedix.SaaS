@inherits LayoutComponentBase

<div class="dm-shell">
    <aside class="dm-shell-sidebar">
        <NavMenu />
    </aside>

    <div class="dm-shell-body">
        <main class="dm-shell-content">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    <div class="dm-blazor-error">
        ⚠️ Ocurrió un error inesperado.
        <a href="." class="dm-err-reload">Recargar página</a>
        <span class="dm-err-dismiss" onclick="this.closest('#blazor-error-ui').style.display='none'">✕</span>
    </div>
</div>

<GlobalLoading />
<GlobalToast />

<style>
    html, body {
        height: 100%;
        margin: 0;
        padding: 0;
        overflow: hidden;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #f1f5f9;
    }

    *, *::before, *::after { box-sizing: border-box; }

    .dm-shell {
        display: grid;
        grid-template-columns: 248px 1fr;
        height: 100vh;
        overflow: hidden;
    }

    .dm-shell-sidebar {
        height: 100vh;
        overflow: hidden;
        background: #0f172a;
        position: sticky;
        top: 0;
    }

    .dm-shell-body {
        display: flex;
        flex-direction: column;
        overflow: hidden;
        height: 100vh;
    }

    .dm-shell-content {
        flex: 1;
        overflow-y: auto;
        padding: 2rem;
    }

    /* Blazor error */
    #blazor-error-ui {
        display: none;
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 1000;
    }

    .dm-blazor-error {
        background: #fef2f2;
        border-top: 2px solid #ef4444;
        color: #991b1b;
        padding: 0.875rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.875rem;
        font-weight: 500;
    }

    .dm-err-reload {
        color: #ef4444;
        font-weight: 700;
        text-decoration: underline;
    }

    .dm-err-dismiss {
        margin-left: auto;
        cursor: pointer;
        color: #dc2626;
        font-size: 1rem;
    }

    /* Responsive */
    @@media (max-width: 1024px) {
        .dm-shell { grid-template-columns: 220px 1fr; }
    }

    @@media (max-width: 768px) {
        .dm-shell { grid-template-columns: 1fr; }
        .dm-shell-sidebar { display: none; }
        .dm-shell-content { padding: 1rem; }
    }
</style>
